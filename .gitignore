# ============================
# Koli One Root .gitignore
# ============================

# --- OS & Editor ---
desktop.ini
Thumbs.db
.DS_Store
*.swp
*.swo
*~
.idea/
.cursor/
.gemini/
.vscode/settings.json
*.iml

# --- Secrets & Credentials ---
*.env
*.env.*
!*.env.example
!*.env.template
.env.local
.env.production
.env.development
.env.test
firebase-service-account.json
google-services.json
GoogleService-Info.plist
*.key
*.pem
*.p12
*.pfx
serviceAccountKey.json
**/serviceAccountKey.json
*-service-account*.json
*serviceaccount*.json

# --- Build artifacts ---
node_modules/
dist/
build/
.cache/
*.bundle

# --- Backup/Temp files ---
*.bak
*.backup
*.tmp
*.orig
*.old
*.ts.backup
*.csv

# --- Reports & generated ---
type-errors-all.txt
type-errors.txt
type-check-errors.txt
tsc-errors.txt
tsc-result.txt
tsc-check-security.txt
ts-prune-report.txt
gitleaks-report.json
cline_mcp_config.json
build_output_*.txt
server-output.txt
errors.md

# --- DDD (deprecated/deleted dump) ---
DDD/

# --- Stray lockfiles (only valid in app dirs) ---
# package-lock.json at root is not valid

# --- Archives ---
*.zip
*.tar.gz
*.7z

server.log
*.log

# --- Build artifacts in submodules ---
web/build/
