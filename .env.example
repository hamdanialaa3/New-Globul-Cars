# ============================================
# Koli One - Environment Variables Template
# ============================================
# ⚠️  انسخ هذا الملف إلى .env.local وأدخل مفاتيحك الحقيقية
# ⚠️  Copy this file to .env.local and enter your real keys

# ============================================
# 🟢 CLIENT-SIDE SAFE KEYS (OK to expose in browser via VITE_)
# These are PUBLIC identifiers — not secrets. They are designed
# to be visible in the browser and are protected by Firebase
# Security Rules, App Check, and domain restrictions.
# ============================================

# Firebase Configuration (PUBLIC - protected by Security Rules)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Google Maps API (PUBLIC - restricted by domain in Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Google API (PUBLIC - restricted by domain)
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Algolia Search (PUBLIC - search-only key, no write access)
VITE_ALGOLIA_APP_ID=your_algolia_app_id_here
VITE_ALGOLIA_SEARCH_KEY=your_algolia_search_only_key_here

# Stripe PUBLISHABLE Key (PUBLIC - designed for client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# hCaptcha Site Key (PUBLIC - the public widget key)
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key

# Facebook App ID (PUBLIC - used for SDK initialization)
VITE_FACEBOOK_APP_ID=your_facebook_app_id

# FCM VAPID Key (PUBLIC - used for push notification subscription)
VITE_FCM_VAPID_KEY=your_vapid_key_from_firebase_console

# Environment
NODE_ENV=development
VITE_ENV=development

# App URLs
VITE_BASE_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api

# Analytics (Optional)
VITE_MIXPANEL_TOKEN=your_mixpanel_token
VITE_SENTRY_DSN=https://your_sentry_dsn

# ============================================
# 🔴 SERVER-SIDE ONLY KEYS (Cloud Functions / Secret Manager)
# ⛔ NEVER prefix these with VITE_ — they must NOT be in the browser bundle
# ⛔ Store in: functions/.env, Cloud Functions env, or Secret Manager
# ============================================
#
# The following keys should ONLY be set in:
# 1. Google Cloud Secret Manager (recommended for production)
# 2. Cloud Functions environment variables
# 3. functions/.env (for local development of Cloud Functions)
#
# --- Payment Secrets ---
# STRIPE_SECRET_KEY=sk_test_...
# EPAY_SECRET_KEY=...
# EASYPAY_SECRET_KEY=...
#
# --- Social Media Tokens (Server-Only) ---
# FACEBOOK_APP_SECRET=...
# FACEBOOK_PAGE_ACCESS_TOKEN=...
# INSTAGRAM_ACCESS_TOKEN=...
# TIKTOK_ACCESS_TOKEN=...
# TWITTER_API_SECRET=...
# LINKEDIN_CLIENT_SECRET=...
#
# --- Captcha ---
# HCAPTCHA_SECRET_KEY=... (verification done server-side)
#
# --- Messaging ---
# WHATSAPP_ACCESS_TOKEN=...
# SENDGRID_API_KEY=SG....
#
# --- AI / ML ---
# GEMINI_API_KEY=...
# OPENAI_API_KEY=...
#
# --- Monitoring ---
# UPTIMEROBOT_API_KEY=...
#
# --- Security ---
# ENCRYPTION_KEY=... (generate: openssl rand -hex 32)
# JWT_SECRET=... (generate: openssl rand -hex 32)

# ============================================
# تعليمات الاستخدام | Usage Instructions
# ============================================
# 1. انسخ هذا الملف: cp .env.example .env.local
# 2. أدخل مفاتيحك الحقيقية في .env.local
# 3. لا تشارك ملف .env.local مع أي شخص
# 4. تأكد من أن .env.local موجود في .gitignore
# 5. ⛔ لا تضع أبداً أسرار خادم (SECRET keys) في ملفات VITE_
# 6. استخدم Secret Manager لجميع أسرار الإنتاج
