# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Stripe Configuration (REQUIRED for payments)
VITE_STRIPE_PUBLIC_KEY=pk_test_51...
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# Environment
NODE_ENV=development
VITE_ENV=development

# App URLs
VITE_BASE_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000/api

# Email Service (Choose one)
# SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Or Mailgun
MAILGUN_API_KEY=your_mailgun_key
MAILGUN_DOMAIN=mg.yourdomain.com

# Analytics (Optional)
# Google Analytics 4 - Use REACT_APP_FIREBASE_MEASUREMENT_ID (already set above)
# Or set separately: REACT_APP_GA4_MEASUREMENT_ID=G-YOUR_MEASUREMENT_ID
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Error Monitoring (Optional)
VITE_SENTRY_DSN=https://your_sentry_dsn

# Push Notifications (FCM - Firebase Cloud Messaging)
# ⚠️ IMPORTANT: Get your VAPID key from Firebase Console:
# 1. Go to: https://console.firebase.google.com/project/fire-new-globul/settings/cloudmessaging
# 2. Scroll to "Web Push certificates" section
# 3. Click "Generate key pair" (if you don't have one)
# 4. Copy the key (starts with 'B', ~86-88 characters long)
# 5. Paste it below (no quotes needed)
# See VAPID_SETUP_GUIDE.md for detailed instructions
VITE_VAPID_KEY=your_vapid_key_from_firebase_console

# ============================================
# SOCIAL MEDIA API KEYS
# ============================================
# See: docs/SOCIAL_MEDIA_API_KEYS_GUIDE.md for detailed setup
# See: docs/QUICK_START_API_SETUP.md for quick start

# --------------------------------------------
# FACEBOOK / META (Facebook + Instagram + Threads)
# --------------------------------------------
FACEBOOK_APP_ID=2026958077871354
FACEBOOK_APP_SECRET=your_app_secret_here
FACEBOOK_ACCESS_TOKEN=your_long_lived_access_token
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_token

# Instagram Business
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_token

# Threads
THREADS_USER_ID=your_threads_user_id
THREADS_ACCESS_TOKEN=same_as_instagram_token

# --------------------------------------------
# YOUTUBE (Google Cloud)
# --------------------------------------------
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token
YOUTUBE_CHANNEL_ID=UCKolionebg_channel_id

# --------------------------------------------
# LINKEDIN
# --------------------------------------------
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_ORG_ID=your_company_page_id

# --------------------------------------------
# X (TWITTER) - Requires Basic Plan ($100/month)
# --------------------------------------------
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token
TWITTER_CLIENT_ID=your_oauth2_client_id
TWITTER_CLIENT_SECRET=your_oauth2_client_secret

# --------------------------------------------
# TIKTOK - Requires approval
# --------------------------------------------
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_USER_ID=mobilebg.eu_user_id

# --------------------------------------------
# AUTOMATION TOOLS (Optional - Pick one)
# --------------------------------------------
# Buffer API
BUFFER_ACCESS_TOKEN=your_buffer_token

# Zapier Webhook
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# --------------------------------------------
# SEO & KEYWORD TOOLS (Optional)
# --------------------------------------------
# RiteTag for hashtag suggestions
RITETAG_ACCESS_TOKEN=your_ritetag_token

# SEMrush for keyword research
SEMRUSH_API_KEY=your_semrush_key

# --------------------------------------------
# AI CONTENT GENERATION (Optional)
# --------------------------------------------
# OpenAI for captions/hashtags
OPENAI_API_KEY=your_openai_key

# Google Gemini (already configured in firebase-service-account.json)
GEMINI_API_KEY=your_gemini_key

# --------------------------------------------
# SECURITY
# --------------------------------------------
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate_secure_32_char_key
JWT_SECRET=generate_secure_jwt_secret
