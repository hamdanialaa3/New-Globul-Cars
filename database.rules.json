{
  "rules": {
    "presence": {
      "$numericId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "channels": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "messages": {
      "$channelId": {
        ".read": "auth != null",
        ".indexOn": [
          "timestamp"
        ],
        "$messageId": {
          ".write": "auth != null"
        }
      }
    },
    "user_channels": {
      "$userNumericId": {
        ".read": "auth != null",
        "$channelId": {
          ".write": "auth != null"
        }
      }
    },
    "typing": {
      "$channelId": {
        ".read": "auth != null",
        "$numericId": {
          ".write": "auth != null"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}