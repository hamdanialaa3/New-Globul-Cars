{
  "rules": {
    // ==================== DEFAULT: DENY ALL ====================
    ".read": false,
    ".write": false,

    // ==================== CHANNELS (Conversations) ====================
    // Path: /channels/{channelId}
    // Channel ID format: msg_{sellerNumericId}_{buyerNumericId}_car_{carNumericId}
    // 🔒 SECURED (2026-02-09): Access restricted to channel participants only
    // Participants are tracked in the channel's 'participants' child node
    "channels": {
      "$channelId": {
        // Read/Write: Only participants of this channel
        // Falls back to auth-only if participants node doesn't exist yet (creation)
        // Backward-compatible: also allows buyerFirebaseId/sellerFirebaseId for old channels without 'participants' node
        ".read": "auth != null && (data.child('participants').child(auth.uid).exists() || !data.exists() || auth.uid == data.child('buyerFirebaseId').val() || auth.uid == data.child('sellerFirebaseId').val())",
        ".write": "auth != null && (data.child('participants').child(auth.uid).exists() || !data.exists() || auth.uid == data.child('buyerFirebaseId').val() || auth.uid == data.child('sellerFirebaseId').val())",
        // Unread count per user — only own count
        "unreadCount": {
          "$userNumericId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },

    // ==================== MESSAGES ====================
    // Path: /messages/{channelId}/{messageId}
    // 🔒 SECURED: Only channel participants can read/write messages
    "messages": {
      "$channelId": {
        // Read: Only participants of the parent channel
        // Backward-compatible: also allows buyerFirebaseId/sellerFirebaseId for old channels
        ".read": "auth != null && (root.child('channels').child($channelId).child('participants').child(auth.uid).exists() || auth.uid == root.child('channels').child($channelId).child('buyerFirebaseId').val() || auth.uid == root.child('channels').child($channelId).child('sellerFirebaseId').val())",
        "$messageId": {
          // Write: Only participants of the parent channel
          // Backward-compatible: also allows buyerFirebaseId/sellerFirebaseId for old channels
          ".write": "auth != null && (root.child('channels').child($channelId).child('participants').child(auth.uid).exists() || auth.uid == root.child('channels').child($channelId).child('buyerFirebaseId').val() || auth.uid == root.child('channels').child($channelId).child('sellerFirebaseId').val())",
          // Validate message structure on creation
          ".validate": "newData.hasChildren(['senderId', 'content', 'timestamp', 'type'])"
        }
      }
    },

    // ==================== USER CHANNELS INDEX ====================
    // Path: /user_channels/{userFirebaseUid}/{channelId}
    // 🔒 SECURED: Users can only read/write their own channel index
    "user_channels": {
      "$userUid": {
        ".read": "auth != null && auth.uid == $userUid",
        ".write": "auth != null && auth.uid == $userUid"
      }
    },

    // ==================== TYPING INDICATORS ====================
    // Path: /typing/{channelId}/{userNumericId}
    // 🔒 SECURED: Only channel participants can set typing indicators
    "typing": {
      "$channelId": {
        // Read: Channel participants only
        // Backward-compatible: also allows buyerFirebaseId/sellerFirebaseId for old channels
        ".read": "auth != null && (root.child('channels').child($channelId).child('participants').child(auth.uid).exists() || auth.uid == root.child('channels').child($channelId).child('buyerFirebaseId').val() || auth.uid == root.child('channels').child($channelId).child('sellerFirebaseId').val())",
        "$userNumericId": {
          ".write": "auth != null && (root.child('channels').child($channelId).child('participants').child(auth.uid).exists() || auth.uid == root.child('channels').child($channelId).child('buyerFirebaseId').val() || auth.uid == root.child('channels').child($channelId).child('sellerFirebaseId').val())"
        }
      }
    },

    // ==================== PRESENCE ====================
    // Path: /presence/{id} — id may be Firebase UID OR numeric user ID
    // 🔒 SECURED: Users can only update their own presence
    // The service stores uid: auth.uid in the data for validation
    "presence": {
      "$userId": {
        // Read: Anyone authenticated (for online status display)
        ".read": "auth != null",
        // Write: Own UID path OR numeric-ID path (validate via uid field in data)
        ".write": "auth != null && (auth.uid == $userId || newData.child('uid').val() == auth.uid)",
        // Validate presence structure
        ".validate": "newData.hasChildren(['status', 'lastSeen'])"
      }
    },

    // ==================== SOCIAL FEED ====================
    "feed": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": false
      }
    },

    // ==================== ADMIN UTILITIES ====================
    // Restricted to Cloud Functions only (via service account)
    "_admin": {
      ".read": false,
      ".write": false
    }
  }
}