{
  "rules": {
    "presence": {
      "$numericId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['status', 'lastSeen']) || newData.hasChildren(['online', 'lastSeen'])"
      }
    },
    "channels": {
      "$channelId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['buyerNumericId', 'sellerNumericId', 'carNumericId', 'buyerFirebaseId', 'sellerFirebaseId'])",
        "metadata": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "messages": {
      "$channelId": {
        ".read": "auth != null",
        "$messageId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId', 'recipientId', 'senderFirebaseId', 'recipientFirebaseId', 'content', 'type', 'timestamp'])"
        }
      }
    },
    "user_channels": {
      "$userNumericId": {
        ".read": "auth != null",
        "$channelId": {
          ".write": "auth != null"
        }
      }
    },
    "typing": {
      "$channelId": {
        ".read": "auth != null",
        "$numericId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['isTyping', 'timestamp'])"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}