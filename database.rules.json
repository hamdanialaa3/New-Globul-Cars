{
  "rules": {
    // ==================== DEFAULT: DENY ALL ====================
    ".read": false,
    ".write": false,

    // ==================== CHANNELS (Conversations) ====================
    // Path: /channels/{channelId}
    // Channel ID format: msg_{sellerNumericId}_{buyerNumericId}_car_{carNumericId}
    // Note: Participant validation is done client-side via Firestore numericId.
    // RTDB rules cannot cross-reference Firestore, so we validate auth only.
    "channels": {
      "$channelId": {
        // Read/Write: Any authenticated user
        // Channel discovery is controlled via /user_channels index
        ".read": "auth != null",
        ".write": "auth != null",
        // Unread count per user
        "unreadCount": {
          "$userNumericId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },

    // ==================== MESSAGES ====================
    // Path: /messages/{channelId}/{messageId}
    "messages": {
      "$channelId": {
        // Read: Any authenticated user (channel discovery is via /user_channels)
        ".read": "auth != null",
        "$messageId": {
          // Write: Authenticated users can create and update messages
          // senderFirebaseId is set client-side for sender identity
          ".write": "auth != null",
          // Validate message structure on creation
          ".validate": "newData.hasChildren(['senderId', 'content', 'timestamp', 'type'])"
        }
      }
    },

    // ==================== USER CHANNELS INDEX ====================
    // Path: /user_channels/{userNumericId}/{channelId}
    // Fast lookup for user's conversations
    // Note: numericId is stored in Firestore (not RTDB), so we allow
    // any authenticated user (including guests) to manage channels.
    // The client validates ownership via Firestore numericId lookup.
    "user_channels": {
      "$userNumericId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    // ==================== TYPING INDICATORS ====================
    // Path: /typing/{channelId}/{userNumericId}
    "typing": {
      "$channelId": {
        // Read/Write: Any authenticated user (channel access controlled via /user_channels)
        ".read": "auth != null",
        "$userNumericId": {
          ".write": "auth != null"
        }
      }
    },

    // ==================== PRESENCE ====================
    // Path: /presence/{userNumericId}
    "presence": {
      "$userNumericId": {
        // Read: Anyone authenticated (for online status display)
        ".read": "auth != null",
        // Write: Any authenticated user (client validates own numericId)
        ".write": "auth != null",
        // Validate presence structure
        ".validate": "newData.hasChildren(['online', 'lastSeen'])"
      }
    },

    // ==================== SOCIAL FEED (Optional - if using RTDB for real-time feed) ====================
    "feed": {
      "$userId": {
        ".read": "auth != null && auth.uid == $userId",
        ".write": false
      }
    },

    // ==================== ADMIN UTILITIES ====================
    // Restricted to Cloud Functions only (via service account)
    "_admin": {
      ".read": false,
      ".write": false
    }
  }
}