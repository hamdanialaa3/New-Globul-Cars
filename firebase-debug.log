[debug] [2026-01-10T13:22:42.845Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/fire-new-globul/rulesets {"name":"projects/fire-new-globul/rulesets/16e83c9e-220f-4227-80ce-9e915dfb11ce","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    // Helper function to check if user is authenticated\r\n    function isAuthenticated() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    // Helper function to check if user is accessing their own data\r\n    function isOwner(userId) {\r\n      return isAuthenticated() && request.auth.uid == userId;\r\n    }\r\n\r\n    // 🔴 CRITICAL FIX: Counters collection - Only Cloud Functions can write\r\n    // Numeric ID counters must be protected to prevent corruption\r\n    match /counters/{counterId} {\r\n      allow read: if true; // Public read OK (for numeric ID lookups)\r\n      // ✅ FIXED: Only Cloud Functions or Admin SDK can write\r\n      // Clients can read but NOT write - prevents numeric ID system corruption\r\n      allow write: if false; // ❌ CRITICAL: Disabled client writes - use Cloud Functions only\r\n    }\r\n\r\n    // Profiles\r\n    match /profiles/{profileId} {\r\n      allow read: if true;\r\n      // ✅ CRITICAL FIX: Allow write if:\r\n      // 1. User owns the profile (userId matches), OR\r\n      // 2. Creating/updating with userId matching auth.uid, OR\r\n      // 3. Updating own profile (profileId == auth.uid) with userId field included\r\n      allow write: if isOwner(resource.data.userId) \r\n        || (request.resource.data.userId == request.auth.uid)\r\n        || (isAuthenticated() \r\n            && request.auth.uid == profileId \r\n            && request.resource.data.userId == request.auth.uid);\r\n    }\r\n    \r\n    // Users collection\r\n    match /users/{userId} {\r\n      allow read: if isAuthenticated();\r\n      allow write: if isOwner(userId);\r\n    }\r\n    \r\n    // Stripe Customers & Checkout Sessions (Explicit Rule)\r\n    match /customers/{uid} {\r\n      allow read: if request.auth.uid == uid;\r\n      allow write: if request.auth.uid == uid;\r\n\r\n      match /checkout_sessions/{id} {\r\n        allow read, write: if request.auth.uid == uid;\r\n      }\r\n      match /subscriptions/{id} {\r\n        allow read: if request.auth.uid == uid;\r\n      }\r\n    }\r\n\r\n    // Cars/Listings\r\n    match /cars/{carId} {\r\n      allow read: if true;\r\n      allow write: if isAuthenticated();\r\n    }\r\n\r\n    // ✅ NEW: Explicitly allow other vehicle types (Restricted to Owner)\r\n    match /passenger_cars/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    match /suvs/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    match /vans/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    match /motorcycles/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    match /trucks/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    match /buses/{carId} { \r\n      allow read: if true; \r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); \r\n    }\r\n    \r\n    // Legacy support for listings collection if used\r\n    match /listings/{listingId} {\r\n      allow read: if true;\r\n      allow write: if isAuthenticated();\r\n    }\r\n    \r\n    match /listingMetrics/{metricId} {\r\n       allow read: if true;\r\n       allow write: if isAuthenticated();\r\n    }\r\n\r\n    // ==================== FOLLOWS COLLECTION ====================\r\n    // Follow System: User-to-User following relationships\r\n    // Document ID format: {followerId}_{followingId}\r\n    // Security:\r\n    // - Read: If you're the follower or the one being followed\r\n    // - Create: If authenticated and not following yourself\r\n    // - Delete: Only if you're the follower (unfollow your own action)\r\n    match /follows/{followId} {\r\n      // Allow reading if you're involved in the relationship\r\n      allow read: if isAuthenticated() && (\r\n        followId.matches('^' + request.auth.uid + '_.*') ||  // You're the follower\r\n        followId.matches('.*_' + request.auth.uid + '$')     // You're being followed\r\n      );\r\n\r\n      // Allow creating a follow if:\r\n      // 1. Authenticated\r\n      // 2. followerId matches your UID\r\n      // 3. Not following yourself (followerId != followingId)\r\n      allow create: if isAuthenticated() \r\n        && request.resource.data.followerId == request.auth.uid\r\n        && request.resource.data.followerId != request.resource.data.followingId\r\n        && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt']);\r\n\r\n      // Allow deleting only if you're the follower (unfollowing)\r\n      allow delete: if isAuthenticated() \r\n        && resource.data.followerId == request.auth.uid;\r\n\r\n      // No updates allowed (follow/unfollow only)\r\n      allow update: if false;\r\n    }\r\n\r\n    // ==================== NOTIFICATIONS COLLECTION ====================\r\n    // Notification System: Real-time alerts for users\r\n    // Security:\r\n    // - Read: Only your own notifications\r\n    // - Create: Only Cloud Functions (deny client writes)\r\n    // - Update: Only to mark as read (isRead field)\r\n    // - Delete: Only your own notifications\r\n    match /notifications/{notificationId} {\r\n      // Read: Only if notification belongs to you\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n\r\n      // Create: Deny (only Cloud Functions can create)\r\n      allow create: if false;\r\n\r\n      // Update: Only mark as read (isRead field)\r\n      allow update: if isAuthenticated() \r\n        && resource.data.userId == request.auth.uid\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);\r\n\r\n      // Delete: Only your own notifications\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // PHASE 3: Team Management (Company Infrastructure)\r\n    // Team Members Sub-collection: users/{companyId}/team_members/{memberId}\r\n    match /users/{companyId}/team_members/{memberId} {\r\n      // Helper: Check if user is the company owner\r\n      function isCompanyOwner() {\r\n        return isAuthenticated() && request.auth.uid == companyId;\r\n      }\r\n\r\n      // Helper: Check if user is an active team admin\r\n      function isTeamAdmin() {\r\n        return exists(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId))\r\n          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.linkedUserId == request.auth.uid\r\n          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.role == 'admin'\r\n          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.status == 'active';\r\n      }\r\n\r\n      // Read: Company owner or active team members\r\n      allow read: if isCompanyOwner() || isTeamAdmin();\r\n\r\n      // Create/Update/Delete: Only company owner or team admins\r\n      allow create, update, delete: if isCompanyOwner() || isTeamAdmin();\r\n    }\r\n\r\n    // Team Invitations Collection: team_invitations/{inviteId}\r\n    match /team_invitations/{inviteId} {\r\n      // Read: Any authenticated user (to check invite codes)\r\n      allow read: if isAuthenticated();\r\n\r\n      // Create: Only company owners\r\n      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;\r\n\r\n      // Update: Only invitation owner (to revoke/accept)\r\n      allow update: if isAuthenticated() && resource.data.companyId == request.auth.uid;\r\n\r\n      // Delete: Only invitation owner\r\n      allow delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== ANALYTICS COLLECTIONS ====================\r\n    // Search Analytics: Track search queries and clicks\r\n    match /searchAnalytics/{analyticsId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // Allow anonymous search tracking\r\n      allow update: if isAuthenticated();\r\n      allow delete: if false; // No deletes\r\n    }\r\n\r\n    match /searchClicks/{clickId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // Allow anonymous click tracking\r\n      allow update: if false; // No updates\r\n      allow delete: if false; // No deletes\r\n    }\r\n\r\n    match /searchAggregates/{aggregateId} {\r\n      allow read: if true; // Public read for popular searches\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated();\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== CAMPAIGNS COLLECTION ====================\r\n    // Marketing Campaigns\r\n    match /campaigns/{campaignId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== CONSULTATIONS COLLECTION ====================\r\n    // Expert Consultations\r\n    match /consultations/{consultationId} {\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.requesterId == request.auth.uid ||\r\n        resource.data.expertId == request.auth.uid\r\n      );\r\n      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;\r\n      allow update: if isAuthenticated() && (\r\n        resource.data.requesterId == request.auth.uid ||\r\n        resource.data.expertId == request.auth.uid\r\n      );\r\n      allow delete: if isAuthenticated() && resource.data.requesterId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== REVIEWS COLLECTION ====================\r\n    // Post-Sale Reviews\r\n    match /reviews/{reviewId} {\r\n      allow read: if true; // Public reviews\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.buyerId == request.auth.uid;\r\n      allow delete: if false; // No review deletion (admin only via backend)\r\n    }\r\n\r\n    // ==================== CAR STORIES COLLECTION ====================\r\n    // User Car Stories and Experience\r\n    // Document ID: userId (one story per user)\r\n    // Security:\r\n    // - Read: Public (anyone can read car stories)\r\n    // - Write: Only owner can create/update their story\r\n    match /carStories/{userId} {\r\n      allow read: if true; // Public read for all car stories\r\n      allow write: if isOwner(userId); // Only owner can edit their story\r\n    }\r\n\r\n    // ==================== INTRO VIDEOS COLLECTION ====================\r\n    // User Introduction Videos\r\n    // Document ID: userId (one video per user)\r\n    // Security:\r\n    // - Read: Public (showcase videos)\r\n    // - Write: Only owner can manage their video\r\n    match /introVideos/{userId} {\r\n      allow read: if true; // Public read\r\n      allow write: if isOwner(userId); // Owner only\r\n    }\r\n\r\n    // ==================== SUCCESS STORIES COLLECTION ====================\r\n    // User Success Stories and Achievements\r\n    // Security:\r\n    // - Read: Public (inspirational stories)\r\n    // - Create: Authenticated users\r\n    // - Update/Delete: Only owner\r\n    match /successStories/{storyId} {\r\n      allow read: if true; // Public read\r\n      allow create: if isAuthenticated();\r\n      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== AVAILABILITY CALENDARS COLLECTION ====================\r\n    // User Availability for Appointments\r\n    // Document ID: userId (one calendar per user)\r\n    // Security:\r\n    // - Read: Public (anyone can see availability)\r\n    // - Write: Only owner can manage their calendar\r\n    match /availabilityCalendars/{userId} {\r\n      allow read: if true; // Public read for booking\r\n      allow write: if isOwner(userId); // Owner only\r\n    }\r\n\r\n    // ==================== ACHIEVEMENTS COLLECTION ====================\r\n    // User Achievements, Badges, and Certificates\r\n    // Security:\r\n    // - Read: Public (showcase achievements)\r\n    // - Write: Only owner or admin (badges awarded by system)\r\n    match /achievements/{achievementId} {\r\n      allow read: if true; // Public read\r\n      allow create: if isAuthenticated();\r\n      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== DRAFTS COLLECTION ====================\r\n    // Car Listing Drafts\r\n    // Security: Only owner can access their drafts\r\n    match /drafts/{draftId} {\r\n      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== EVENTS COLLECTION ====================\r\n    // Community Events\r\n    // Security:\r\n    // - Read: Public\r\n    // - Create: Authenticated users\r\n    // - Update/Delete: Owner only\r\n    match /events/{eventId} {\r\n      allow read: if true; // Public events\r\n      allow create: if isAuthenticated();\r\n      allow update, delete: if isAuthenticated() && resource.data.organizerId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== EVENT RSVPs COLLECTION ====================\r\n    // Event Attendance Tracking\r\n    match /eventRSVPs/{rsvpId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== LEADERBOARDS COLLECTION ====================\r\n    // User Rankings and Scores\r\n    // Security: Public read, system writes only\r\n    match /leaderboards/{userId} {\r\n      allow read: if true; // Public leaderboard\r\n      allow write: if false; // System/Cloud Functions only\r\n    }\r\n\r\n    // ==================== SAVED SEARCHES COLLECTION ====================\r\n    // User Saved Search Filters\r\n    match /savedSearches/{searchId} {\r\n      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== SOCIAL MEDIA ACCOUNTS COLLECTION ====================\r\n    // Linked Social Media Profiles\r\n    // Document ID: userId\r\n    match /socialMediaAccounts/{userId} {\r\n      allow read: if true; // Public profiles\r\n      allow write: if isOwner(userId); // Owner only\r\n    }\r\n\r\n    // ==================== TRANSACTIONS COLLECTION ====================\r\n    // Financial Transactions\r\n    // Security: Strict owner-only access\r\n    match /transactions/{transactionId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update, delete: if false; // No modifications (audit trail)\r\n    }\r\n\r\n    // ==================== TRUST CONNECTIONS COLLECTION ====================\r\n    // Trust Network Relationships\r\n    match /trustConnections/{connectionId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;\r\n      allow update: if isAuthenticated() && (\r\n        resource.data.requesterId == request.auth.uid ||\r\n        resource.data.receiverId == request.auth.uid\r\n      );\r\n      allow delete: if isAuthenticated() && resource.data.requesterId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== WORKFLOW ANALYTICS COLLECTION ====================\r\n    // System Analytics (Admin/Cloud Functions)\r\n    match /workflow_analytics/{analyticsId} {\r\n      allow read: if isAuthenticated(); // Users can read aggregate stats\r\n      allow write: if false; // System only\r\n    }\r\n\r\n    // ==================== DEALERSHIPS COLLECTION ====================\r\n    // Verified Dealerships/Companies\r\n    match /dealerships/{dealershipId} {\r\n      allow read: if true; // Public read for all verified dealerships\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;\r\n      allow delete: if false; // No deletion (admin only via backend)\r\n    }\r\n\r\n    // ==================== POSTS COLLECTION (Social Feed) ====================\r\n    // Community Posts\r\n    match /posts/{postId} {\r\n      allow read: if true; // Public posts visible to everyone\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n\r\n      // Comments sub-collection\r\n      match /comments/{commentId} {\r\n        allow read: if true; // Public comments\r\n        allow create: if isAuthenticated();\r\n        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      }\r\n\r\n      // Likes sub-collection\r\n      match /likes/{likeId} {\r\n        allow read: if true; // Public likes count\r\n        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n        allow update: if false; // No updates to likes\r\n      }\r\n    }\r\n\r\n    // ==================== FAVORITES COLLECTION ====================\r\n    // User Favorites (saved cars)\r\n    match /favorites/{favoriteId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow update: if false; // No updates to favorites\r\n    }\r\n\r\n    // 🔴 CRITICAL: Blocked Users Collection (January 2026 - User Safety)\r\n    // Block relationships between users\r\n    match /blocked_users/{blockId} {\r\n      // Read: Only if you're involved in the block relationship\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.blockerFirebaseId == request.auth.uid ||\r\n        resource.data.blockedFirebaseId == request.auth.uid\r\n      );\r\n\r\n      // Create: Only if you're the blocker (can't block on behalf of others)\r\n      allow create: if isAuthenticated() \r\n        && request.resource.data.blockerFirebaseId == request.auth.uid\r\n        && request.resource.data.blockerFirebaseId != request.resource.data.blockedFirebaseId // Can't block yourself\r\n        && request.resource.data.keys().hasAll(['blockerNumericId', 'blockerFirebaseId', 'blockedNumericId', 'blockedFirebaseId', 'createdAt', 'updatedAt']);\r\n\r\n      // Update: Only if you're the blocker (can update reason)\r\n      allow update: if isAuthenticated() \r\n        && resource.data.blockerFirebaseId == request.auth.uid\r\n        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reason', 'updatedAt']);\r\n\r\n      // Delete: Only if you're the blocker (can unblock)\r\n      allow delete: if isAuthenticated() && resource.data.blockerFirebaseId == request.auth.uid;\r\n    }\r\n\r\n    // 🔴 CRITICAL: Reports Collection (January 2026 - Content Moderation)\r\n    // User reports for spam, abuse, fake content\r\n    match /reports/{reportId} {\r\n      // Read: Only if you're the reporter (users can see their own reports)\r\n      allow read: if isAuthenticated() && resource.data.reporterFirebaseId == request.auth.uid;\r\n\r\n      // Create: Only authenticated users can create reports\r\n      allow create: if isAuthenticated()\r\n        && request.resource.data.reporterFirebaseId == request.auth.uid\r\n        && request.resource.data.reporterFirebaseId != request.resource.data.reportedUserFirebaseId // Can't report yourself\r\n        && request.resource.data.keys().hasAll(['reporterFirebaseId', 'reporterNumericId', 'reportedUserFirebaseId', 'reportedUserNumericId', 'reportType', 'contentType', 'reason', 'description', 'status', 'createdAt', 'updatedAt']);\r\n\r\n      // Update: Only admins can update reports (via Cloud Functions)\r\n      allow update: if false; // Only Cloud Functions can update\r\n\r\n      // Delete: No deletes (archival only)\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== MESSAGES & CONVERSATIONS ====================\r\n    // Direct Messages\r\n    match /messages/{messageId} {\r\n      allow read: if isAuthenticated() && (\r\n        resource.data.senderId == request.auth.uid ||\r\n        resource.data.recipientId == request.auth.uid\r\n      );\r\n      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;\r\n      allow update: if isAuthenticated() && (\r\n        resource.data.senderId == request.auth.uid ||\r\n        resource.data.recipientId == request.auth.uid\r\n      );\r\n      allow delete: if false; // No message deletion\r\n    }\r\n\r\n    // Conversations metadata\r\n    match /conversations/{conversationId} {\r\n      allow read: if isAuthenticated() && (\r\n        conversationId.matches('.*' + request.auth.uid + '.*')\r\n      );\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && (\r\n        conversationId.matches('.*' + request.auth.uid + '.*')\r\n      );\r\n      allow delete: if false; // No conversation deletion\r\n    }\r\n\r\n    // ==================== ANALYTICS EVENTS & METRICS ====================\r\n    // Profile Analytics: Track profile views, car views, inquiries\r\n    match /analytics_events/{eventId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // Allow anonymous tracking\r\n      allow update: if false; // No updates\r\n      allow delete: if false; // No deletes\r\n    }\r\n\r\n    match /profile_analytics/{userId} {\r\n      allow read: if isAuthenticated() && request.auth.uid == userId;\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /profile_metrics/{userId} {\r\n      allow read: if isAuthenticated() && request.auth.uid == userId;\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates metrics\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== USER POINTS & LEVELS ====================\r\n    match /userPoints/{userId} {\r\n      allow read: if isAuthenticated() && request.auth.uid == userId;\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates points\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== PROFILE STATS ====================\r\n    match /profile_stats/{statsId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /profiles/{profileId} {\r\n      allow read: if true;\r\n      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid);\r\n    }\r\n\r\n    // ==================== SAVED SEARCHES ====================\r\n    match /saved_searches/{searchId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== LISTING REVIEWS ====================\r\n    match /listing_reviews/{reviewId} {\r\n      allow read: if true; // Public reviews\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== SEARCH ANALYTICS ====================\r\n    match /searchAnalytics/{analyticsId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // Allow anonymous\r\n      allow update: if isAuthenticated();\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /searchClicks/{clickId} {\r\n      allow read: if isAuthenticated();\r\n      allow create: if true; // Allow anonymous\r\n      allow update: if false;\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== LEADERBOARD ====================\r\n    match /leaderboard/{entryId} {\r\n      allow read: if true; // Public leaderboard\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== CHALLENGES ====================\r\n    // Monthly Challenges System\r\n    match /challenges/{challengeId} {\r\n      allow read: if true; // Public challenges\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;\r\n    }\r\n\r\n    // Monthly Challenges (New Collection Name)\r\n    match /monthlyChallenges/{challengeId} {\r\n      allow read: if true; // Public challenges\r\n      allow create: if isAuthenticated();\r\n      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;\r\n    }\r\n\r\n    // User Challenge Progress (Old Collection Name)\r\n    match /user_challenges/{entryId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // User Challenge Progress (New Collection Name)\r\n    match /userChallengeProgress/{entryId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== STORIES ====================\r\n    match /stories/{storyId} {\r\n      allow read: if true; // Public stories\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== ACHIEVEMENTS ====================\r\n    match /achievements/{achievementId} {\r\n      allow read: if true; // Public achievements\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /user_achievements/{entryId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== BADGES ====================\r\n    match /badges/{badgeId} {\r\n      allow read: if true; // Public badges\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    match /user_badges/{entryId} {\r\n      allow read: if true; // Public user badges\r\n      allow create: if true; // System creates\r\n      allow update: if true; // System updates\r\n      allow delete: if false;\r\n    }\r\n\r\n    // ==================== SEARCH HISTORY ====================\r\n    match /searchHistory/{historyId} {\r\n      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;\r\n      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // ==================== USER GROUPS & MEMBERSHIPS ====================\r\n    // User Groups (Community Feature)\r\n    match /userGroups/{groupId} {\r\n      // Allow reading groups (public groups or browsing)\r\n      allow read: if true;\r\n      // Allow creating groups if authenticated\r\n      allow create: if isAuthenticated();\r\n      // Allow updates if authenticated (ideally restricted to group admins)\r\n      allow update: if isAuthenticated();\r\n      // Delete not allowed (archive instead)\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Group Memberships\r\n    match /groupMemberships/{membershipId} {\r\n      // Allow reading memberships to check status (Public for profile views)\r\n      // Required for getUserMemberships query on public profiles\r\n      allow read: if true;\r\n      \r\n      // Allow joining (creating membership) for yourself\r\n      allow create: if isAuthenticated() \r\n        && request.resource.data.userId == request.auth.uid;\r\n        \r\n      // Allow updating own membership (e.g., settings)\r\n      allow update: if isAuthenticated() \r\n        && resource.data.userId == request.auth.uid;\r\n        \r\n      // Allow leaving (deleting membership)\r\n      allow delete: if isAuthenticated() \r\n        && resource.data.userId == request.auth.uid;\r\n    }\r\n\r\n    // General fallback (deny by default, but opened for dev/debugging if needed - keep strict for now)\r\n    // Default: Deny all other access\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-01-10T13:22:42.510207Z","metadata":{"services":["cloud.firestore"]}}
