{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Listing Document Schema",
  "description": "Canonical schema for vehicle listings in Firestore listings collection",
  "type": "object",
  "required": ["listingId", "listingNumericId", "sellerId", "brandId", "modelId", "year", "price", "currency", "mileage", "status", "createdAt"],
  "properties": {
    "listingId": {
      "type": "string",
      "description": "Unique identifier (UUID)"
    },
    "listingNumericId": {
      "type": "integer",
      "description": "Unique numeric ID for SEO-friendly URLs, auto-increment"
    },
    "sellerId": {
      "type": "string",
      "description": "FK to users.userId"
    },
    "sellerNumericId": {
      "type": "integer",
      "description": "FK to users.userNumericId (for legacy route /car/{sellerNumericId}/{listingNumericId})"
    },
    "title": {
      "type": "string",
      "description": "Listing title, used for slug generation"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly slug, unique"
    },
    "canonicalUrl": {
      "type": "string",
      "description": "Canonical URL path (e.g. /car/540/alaa-320d-sport), computed field"
    },
    "brandId": {
      "type": "string",
      "description": "Reference to taxonomy.v1.json brands[].id"
    },
    "modelId": {
      "type": "string",
      "description": "Reference to taxonomy.v1.json models[].id"
    },
    "generationId": {
      "type": "string",
      "description": "Reference to taxonomy.v1.json models[].generations[].id"
    },
    "trimId": {
      "type": "string",
      "description": "Reference to taxonomy.v1.json trim or custom string"
    },
    "year": {
      "type": "integer",
      "description": "Model year"
    },
    "mileage": {
      "type": "integer",
      "description": "Odometer reading in kilometers or miles (store unit separately)"
    },
    "mileageUnit": {
      "type": "string",
      "enum": ["km", "mi"],
      "description": "Unit of mileage measurement"
    },
    "price": {
      "type": "number",
      "description": "Listing price"
    },
    "currency": {
      "type": "string",
      "enum": ["EUR", "BGN", "USD", "AED", "SAR"],
      "description": "ISO 4217 currency code"
    },
    "fuelType": {
      "type": "string",
      "description": "Reference to taxonomy fuelTypes[].id"
    },
    "transmission": {
      "type": "string",
      "description": "Reference to taxonomy transmissions[].id"
    },
    "bodyType": {
      "type": "string",
      "description": "Reference to taxonomy bodyTypes[].id"
    },
    "condition": {
      "type": "string",
      "description": "Reference to taxonomy conditions[].id"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the vehicle"
    },
    "media": {
      "type": "array",
      "description": "Array of image/video URLs (gs:// for Cloud Storage or CDN URLs)",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string" },
          "type": { "type": "string", "enum": ["image", "video"] },
          "position": { "type": "integer" },
          "uploadedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "location": {
      "type": "object",
      "properties": {
        "city": { "type": "string" },
        "region": { "type": "string" },
        "country": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      }
    },
    "features": {
      "type": "array",
      "description": "Array of feature tags (ac, sunroof, leather, etc.)",
      "items": { "type": "string" }
    },
    "aiSuggestions": {
      "type": "object",
      "properties": {
        "estimatedPrice": {
          "type": "number",
          "description": "AI-generated price estimate"
        },
        "pricingConfidence": {
          "type": "number",
          "description": "0-100 confidence score"
        },
        "qualityScore": {
          "type": "number",
          "description": "0-100 listing quality based on completeness and photos"
        },
        "suggestedFeatures": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived", "sold"],
      "description": "Listing status"
    },
    "viewCount": {
      "type": "integer",
      "description": "Number of profile views"
    },
    "inquiryCount": {
      "type": "integer",
      "description": "Number of inquiries received"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "archivedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "example": {
    "listingId": "uuid-abc-123",
    "listingNumericId": 540,
    "sellerId": "firebase-uuid-1",
    "sellerNumericId": 1,
    "title": "ALAA 320d Sport",
    "slug": "alaa-320d-sport",
    "canonicalUrl": "/car/540/alaa-320d-sport",
    "brandId": "bmw",
    "modelId": "3-series",
    "year": 2017,
    "price": 9800,
    "currency": "EUR",
    "mileage": 120000,
    "mileageUnit": "km",
    "fuelType": "diesel",
    "transmission": "manual",
    "status": "published",
    "createdAt": "2026-02-18T23:30:00Z"
  }
}
