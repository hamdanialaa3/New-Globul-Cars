{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://koli.one/schemas/campaign.v1.json",
  "title": "Campaign",
  "description": "Promotional campaign for car listings or profile boosts on Koli One. Budget in EUR.",
  "type": "object",
  "required": ["id", "userId", "type", "status", "budget", "startDate", "title"],
  "properties": {
    "id": { "type": "string" },
    "userId": { "type": "string", "description": "Firebase Auth UID of campaign owner" },
    "carId": { "type": "string", "description": "Target listing Firestore ID (optional for profile boosts)" },

    "type": {
      "type": "string",
      "enum": ["car_listing", "profile_boost", "featured", "homepage"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "paused", "completed", "cancelled"]
    },

    "title": { "type": "string" },
    "description": { "type": "string" },

    "budget": { "type": "number", "minimum": 0, "description": "Total budget in EUR" },
    "spent": { "type": "number", "minimum": 0 },
    "dailyBudget": { "type": "number", "minimum": 0 },

    "startDate": { "type": "string", "format": "date-time" },
    "endDate": { "type": "string", "format": "date-time" },
    "duration": { "type": "integer", "description": "Days" },

    "targetRegions": { "type": "array", "items": { "type": "string" } },
    "targetAudience": {
      "type": "object",
      "properties": {
        "minAge": { "type": "integer" },
        "maxAge": { "type": "integer" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "carBrands": { "type": "array", "items": { "type": "string" } }
      }
    },

    "impressions": { "type": "integer", "minimum": 0 },
    "clicks": { "type": "integer", "minimum": 0 },
    "views": { "type": "integer", "minimum": 0 },
    "inquiries": { "type": "integer", "minimum": 0 },
    "conversions": { "type": "integer", "minimum": 0 },
    "ctr": { "type": "number", "description": "Click-through rate %" },
    "cpc": { "type": "number", "description": "Cost per click EUR" },
    "cpa": { "type": "number", "description": "Cost per acquisition EUR" },
    "roi": { "type": "number", "description": "Return on investment %" },

    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
