{
  "name": "globul-cars-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Bulgarian Car Marketplace - Modular Monorepo Architecture",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@globul-cars/app",
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build --workspace=@globul-cars/app",
    "build:all": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "install:all": "npm install",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hamdanialaa3/New-Globul-Cars.git"
  },
  "author": "Al-Hamdani Alaa",
  "license": "MIT"
}

