# Bulgarian Car Marketplace - Environment Variables Template
# Generated: 2025-11-21T23:57:44.010Z
# Copy this file to .env and fill in your actual values

# ==========================================
# REQUIRED VARIABLES (App won't start without these)
# ==========================================

# Firebase API Key - Get from Firebase Console
# Example: AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_FIREBASE_API_KEY=

# Firebase Auth Domain
# Example: your-project.firebaseapp.com
REACT_APP_FIREBASE_AUTH_DOMAIN=

# Firebase Project ID
# Example: your-project-id
REACT_APP_FIREBASE_PROJECT_ID=

# Firebase Storage Bucket
# Example: your-project.appspot.com
REACT_APP_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging Sender ID
# Example: 123456789012
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID
# Example: 1:123456789012:web:abcdef123456
REACT_APP_FIREBASE_APP_ID=

# Google reCAPTCHA Site Key - Get from https://www.google.com/recaptcha/admin
# Example: 6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_RECAPTCHA_SITE_KEY=

# Google Maps API Key - Required for maps, fallback to Leaflet if missing
# Example: AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REACT_APP_GOOGLE_MAPS_API_KEY=

# ==========================================
# OPTIONAL VARIABLES (App works without these but with reduced functionality)
# ==========================================

# hCaptcha Site Key - Alternative to reCAPTCHA
# Example: 10000000-ffff-ffff-ffff-000000000001
# REACT_APP_HCAPTCHA_SITE_KEY=

# Supabase URL - Optional supplementary storage
# Example: https://xxxxx.supabase.co
# REACT_APP_SUPABASE_URL=

# Supabase Anonymous Key
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# REACT_APP_SUPABASE_ANON_KEY=

# Facebook App ID - For OAuth and Pixel
# Example: 1234567890123456
# REACT_APP_FACEBOOK_APP_ID=

# Socket.io Server URL - For real-time messaging
# Example: https://your-socket-server.com
# REACT_APP_SOCKET_SERVER_URL=

