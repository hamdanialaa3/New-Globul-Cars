rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public readable assets (e.g., site images)
    match /public/{allPublic=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true; // restrict writes to admins/functions
    }

    // User profile pictures under users/{uid}/profile/
    match /users/{uid}/profile/{fileName} {
      // Only the owner or admin can read/write
      allow read: if true; // or restrict: request.auth != null && request.auth.uid == uid
      allow write: if request.auth != null && (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // Car images under cars/{carId}/images/
    match /cars/{carId}/images/{imageFile} {
      // Allow public read of car images
      allow read: if true;
      // Writes allowed only for authenticated users
      allow write: if request.auth != null;
    }
    
    // Optimized image variants under cars/{carId}/optimized/{variantFile}
    match /cars/{carId}/optimized/{variantFile} {
      // Public read for optimized variants (generated by Cloud Functions)
      allow read: if true;
      // Only Cloud Functions can write optimized variants (no direct user writes)
      allow write: if false;
    }

    // Post media under posts/{userId}/
    match /posts/{userId}/{fileName} {
      // Public read for all post images
      allow read: if true;
      // Only authenticated user can upload to their own folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default: deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}