rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check file size limit (10MB for images, 50MB for videos)
    function isImageWithinLimit() {
      return request.resource.size < 10 * 1024 * 1024; // 10MB
    }

    function isVideoWithinLimit() {
      return request.resource.size < 50 * 1024 * 1024; // 50MB
    }

    // Validate file is an image
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Validate file is a video
    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    // Validate file is an image or video
    function isMediaFile() {
      return isImage() || isVideo();
    }

    // Validate file is a document (PDF, etc.)
    function isDocument() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('image/.*');
    }

    // Workflow Images - Used during car listing creation
    // CRITICAL: Must be publicly readable for published car listings
    match /workflow-images/{userId}/{allPaths=**} {
      allow read: if true; // Public read for published car images
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }

    // User Profile Pictures & Photos
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }
    match /profile-photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }
    match /users/{userId}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }
    match /users/{userId}/cover/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }

    // User Documents & Private Data
    match /users/{userId}/documents/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isDocument() && request.resource.size < 20 * 1024 * 1024; // 20MB
    }
    match /verification-documents/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isDocument() && request.resource.size < 20 * 1024 * 1024;
    }
    
    // Dealership Documents (Private)
    match /dealerships/{userId}/documents/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isDocument() && request.resource.size < 20 * 1024 * 1024;
    }

    // Dealership Logos (Public Read, Owner Write)
    match /dealerships/{userId}/{filename} {
      allow read: if filename.matches('logo-.*');
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }

    // Dealership Media (Public Read)
    match /dealerships/{userId}/media/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isMediaFile() && (
        (isImage() && isImageWithinLimit()) ||
        (isVideo() && isVideoWithinLimit())
      );
    }

    // Social & Shared Content
    match /stories/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isMediaFile() && (
        (isImage() && isImageWithinLimit()) ||
        (isVideo() && isVideoWithinLimit())
      );
    }
    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }
    match /intro-videos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isVideo() && isVideoWithinLimit();
    }

    // Car Images — 🔒 SECURED: Per-user ownership + file type & size validation
    match /car-images/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && isImageWithinLimit();
    }

    // Messages — 🔒 SECURED: Only channel participants can access chat files
    // Participants must be verified via chatId structure (msg_{seller}_{buyer}_car_{car})
    match /messages/{chatId}/{allPaths=**} {
      allow read: if isAuthenticated() && (
        request.auth.uid in chatId ||
        firestore.exists(/databases/(default)/documents/message_participants/$(chatId)/members/$(request.auth.uid))
      );
      allow write: if isAuthenticated() && (
        request.auth.uid in chatId ||
        firestore.exists(/databases/(default)/documents/message_participants/$(chatId)/members/$(request.auth.uid))
      ) && isMediaFile() && (
        (isImage() && isImageWithinLimit()) ||
        (isVideo() && isVideoWithinLimit())
      );
    }
    
    // ⛔ DEFAULT: Block everything not explicitly allowed above
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
