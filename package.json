{
  "name": "koli-one",
  "version": "0.1.0",
  "private": true,
  "homepage": "/",
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.4",
    "@datadog/browser-rum": "^6.31.0",
    "@google/generative-ai": "^0.24.1",
    "@hcaptcha/react-hcaptcha": "^1.12.1",
    "@react-google-maps/api": "^2.20.7",
    "@sentry/react": "^10.32.1",
    "@sentry/tracing": "^7.120.4",
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^3.5.0",
    "algoliasearch": "^4.25.2",
    "axios": "^1.13.2",
    "browser-image-compression": "^2.0.2",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.3.0",
    "framer-motion": "^12.23.26",
    "html2canvas": "^1.4.1",
    "instantsearch.css": "^8.9.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.544.0",
    "openai": "^6.15.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-ga4": "^2.1.0",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.48.0",
    "react-icons": "^5.5.0",
    "react-instantsearch-hooks-web": "^6.47.3",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.9.1",
    "react-toastify": "^11.0.5",
    "react-virtuoso": "^4.6.2",
    "recharts": "^3.2.1",
    "styled-components": "^6.1.19",
    "web-vitals": "^2.1.4",
    "zod": "^3.25.76"
  },
  "scripts": {
    "start": "vite",
    "start:dev": "vite",
    "prebuild": "node scripts/code-quality/ban-console.js",
    "build": "vite build && npm run generate:sitemap",
    "generate:sitemap": "tsx src/scripts/generate-sitemap.ts",
    "check-security": "node scripts/diagnostics/check-env-files.js",
    "security-audit": "node scripts/diagnostics/check-env-files.js",
    "check-secrets": "echo 'Run trufflehog manually or use security-audit'",
    "ci:strict": "npm ci --no-audit --no-fund",
    "preview": "vite preview",
    "build:analyze": "npm run build && npx source-map-explorer 'build/assets/*.js'",
    "build:optimized": "npm run build && node scripts/build/optimize-images.js",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:profile-stats": "node scripts/diagnostics/pretest-profile-stats.js && vitest run --testPathPattern=profile-stats.service.adapter.test.js",
    "test:check": "node scripts/diagnostics/check-test-structure.js",
    "test:fix": "node scripts/migrations/fix-jest-mocks.js && npm run test:check",
    "lint": "echo 'Linting disabled - using build for type checking'",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "serve": "firebase serve --only hosting",
    "emulate": "firebase emulators:start",
    "migrate:legacy-cars": "node scripts/migrations/run-migration.js",
    "type-check": "cross-env NODE_OPTIONS=--max_old_space_size=12288 tsc --noEmit --skipLibCheck",
    "audit:hygiene": "tsx scripts/phase0-preparation/repo-hygiene-audit.ts",
    "audit:hygiene:strict": "tsx scripts/phase0-preparation/repo-hygiene-audit.ts src mobile_new/src functions/src shared",
    "train-ai": "node scripts/dev/train-ai-on-project.js",
    "train-ai:watch": "nodemon --watch src --exec npm run train-ai",
    "clean": "node scripts/cleanup/clean-all.js",
    "clean:ports": "node scripts/cleanup/clean-all.js",
    "clean:cache": "npm cache clean --force && rm -rf node_modules/.cache .cache build dist",
    "clean:all": "npm run clean && npm run clean:cache",
    "clean:3000": "node scripts/cleanup/clean-port-3000.js",
    "doctor:vscode": "pwsh -File scripts/migrations/fix-vscode-copilot.ps1",
    "fix:vscode": "pwsh -File scripts/migrations/fix-vscode-copilot.ps1 -Apply -RestartVSCode",
    "scrape": "ts-node scripts/scrapers/run-scraper.ts",
    "migrate:dealer-limits": "ts-node scripts/firebase-admin/migrate-dealer-limits.ts",
    "deploy:subscription-system": "bash scripts/deploy/deploy-subscription-system.sh",
    "deploy:subscription-system:skip-tests": "bash scripts/deploy/deploy-subscription-system.sh --skip-tests"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/firebase": "^2.4.32",
    "@types/jest": "^27.5.2",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-icons": "^2.2.7",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-styled-components": "^2.1.4",
    "buffer": "^6.0.3",
    "chalk": "^5.6.2",
    "cheerio": "^1.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "firebase-tools": "^15.8.0",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.3",
    "ora": "^9.0.0",
    "postcss": "^8.5.6",
    "process": "^0.11.10",
    "puppeteer": "^24.34.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "url": "^0.11.4",
    "user-agents": "^1.1.669",
    "util": "^0.12.5",
    "vite": "^7.3.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-ssg": "^0.1.0",
    "vite-ssg-sitemap": "^0.10.0",
    "vitest": "^4.0.18",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "overrides": {
    "undici": ">=7.24.4",
    "qs": ">=6.15.0",
    "serialize-javascript": ">=7.0.3",
    "tar": ">=7.5.11",
    "@tootallnate/once": ">=3.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
