rules_version = '2';

// Firestore Security Rules for Globul Cars Bulgarian Marketplace
// قواعد الأمان لقاعدة بيانات Firestore - PRODUCTION VERSION
// ✅ Ready for real users and production environment

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }
    
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin() || isSuperAdmin();
    }

    // PRODUCTION RULES - آمنة للاستخدام الحقيقي
    
    // Users collection - الحسابات
    match /users/{userId} {
      // القراءة: للمستخدم نفسه أو الأدمن
      allow read: if isOwnerOrAdmin(userId);
      // الكتابة: للمستخدم نفسه فقط
      allow create: if isSignedIn() && request.auth.uid == userId;
      // 🎯 FIXED: Allow profileType changes (with validation)
      allow update: if isOwnerOrAdmin(userId) && (
        // If profileType is being changed, validate it's one of the allowed values
        !('profileType' in request.resource.data) ||
        request.resource.data.profileType in ['private', 'dealer', 'company']
      );
      allow delete: if isSuperAdmin();
    }
    
    // Cars collection - السيارات
    match /cars/{carId} {
      // القراءة: الجميع يمكنهم قراءة السيارات النشطة
      allow get: if resource.data.status == 'active' || 
                    isOwnerOrAdmin(resource.data.sellerId) ||
                    isAdmin();
      
      // List & Aggregation: الجميع يمكنهم عرض وعد السيارات النشطة
      allow list: if true; // Required for queries and aggregations
      
      // الكتابة: للمالك والأدمن فقط
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.sellerId;
      allow update: if isOwnerOrAdmin(resource.data.sellerId);
      allow delete: if isOwnerOrAdmin(resource.data.sellerId);
    }
    
    // Messages collection - الرسائل
    match /messages/{messageId} {
      allow read: if isSignedIn() && 
                     (request.auth.uid == resource.data.senderId || 
                      request.auth.uid == resource.data.receiverId ||
                      isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && 
                       (request.auth.uid == resource.data.senderId || 
                        request.auth.uid == resource.data.receiverId);
      allow delete: if isAdmin();
    }
    
    // Favorites collection - المفضلة
    match /favorites/{userId} {
      allow read, write: if isOwnerOrAdmin(userId);
    }
    
    // Saved searches collection - البحوثات المحفوظة
    match /savedSearches/{userId} {
      allow read, write: if isOwnerOrAdmin(userId);
    }
    
    // Reviews collection - التقييمات
    match /reviews/{reviewId} {
      allow read: if true; // الجميع يمكنهم قراءة التقييمات
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Analytics collection - التحليلات (Admin only)
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }
    
    // Stats collection - الإحصائيات (Read-only for users)
    match /stats/{document=**} {
      allow read: if true; // Public stats
      allow write: if false; // Only via Cloud Functions
    }
    
    // Notifications collection - الإشعارات
    match /notifications/{userId} {
      allow read: if isOwnerOrAdmin(userId);
      allow write: if false; // Only via Cloud Functions
    }

  }
}
