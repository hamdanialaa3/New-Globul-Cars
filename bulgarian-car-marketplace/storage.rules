rules_version = '2';

// Storage Security Rules for Globul Cars - Bulgarian Marketplace
// قواعد أمان التخزين - سوق السيارات البلغاري
// الموقع: بلغاريا | اللغات: BG/EN | العملة: EUR

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check file size
    function isValidSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }
    
    // Helper function to check if file is an image
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    // ==================== USER PROFILE IMAGES ====================
    
    // Profile images (avatar/photo)
    match /users/{userId}/profile/{imageFile} {
      // Anyone can read (public profiles)
      allow read: if true;
      
      // Only owner can upload/update/delete
      // Any image, max 10MB (simplified!)
      allow write: if isOwner(userId) && 
                      isImage() &&
                      isValidSize(10);
    }
    
    // Cover images
    match /users/{userId}/cover/{imageFile} {
      // Anyone can read (public)
      allow read: if true;
      
      // Only owner can upload/update/delete
      // Any image, max 15MB (simplified!)
      allow write: if isOwner(userId) && 
                      isImage() &&
                      isValidSize(15);
    }
    
    // Gallery images
    match /users/{userId}/gallery/{imageFile} {
      // Anyone can read
      allow read: if true;
      
      // Only owner can write
      // Any image, max 10MB
      allow write: if isOwner(userId) && 
                      isImage() &&
                      isValidSize(10);
    }
    
    // ==================== DOCUMENTS (PRIVATE) ====================
    
    // ID verification documents (private!)
    match /users/{userId}/documents/{docFile} {
      // Only owner or admin can read
      allow read: if isOwner(userId);
      
      // Only owner can write
      // Any file type, max 5MB
      allow write: if isOwner(userId) && isValidSize(5);
    }
    
    // ==================== CAR IMAGES ====================
    
    // Car listing images
    match /cars/{carId}/images/{imageFile} {
      // Anyone can read
      allow read: if true;
      
      // Authenticated users can write
      // Any image, max 10MB
      allow write: if isAuthenticated() && 
                      isImage() &&
                      isValidSize(10);
    }
    
    // ==================== PUBLIC ASSETS ====================
    
    // Public assets (logos, etc)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Only via admin
    }
    
    // ==================== CATCH ALL ====================
    
    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}