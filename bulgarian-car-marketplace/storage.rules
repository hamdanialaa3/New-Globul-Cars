rules_version = '2';

// Storage Rules - SIMPLIFIED for Bulgarian Car Marketplace
// قواعد مبسطة جداً للتخزين
// الموقع: بلغاريا | اللغات: BG/EN | العملة: EUR

service firebase.storage {
  match /b/{bucket}/o {
    
    // ==================== USER PROFILE IMAGES ====================
    
    // Profile images - أي مستخدم مسجل يمكنه الرفع
    match /users/{userId}/profile/{allPaths=**} {
      // Public read
      allow read: if true;
      
      // Authenticated write (owner only)
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 10 * 1024 * 1024; // 10MB
    }
    
    // Cover images - أي صورة مستطيلة
    match /users/{userId}/cover/{allPaths=**} {
      // Public read
      allow read: if true;
      
      // Authenticated write (owner only)
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 15 * 1024 * 1024; // 15MB
    }
    
    // Gallery images
    match /users/{userId}/gallery/{allPaths=**} {
      // Public read
      allow read: if true;
      
      // Authenticated write (owner only)
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 10 * 1024 * 1024; // 10MB
    }
    
    // ==================== CAR IMAGES ====================
    
    // Car images - للإعلانات
    match /cars/{carId}/{allPaths=**} {
      // Public read
      allow read: if true;
      
      // Authenticated write
      allow write: if request.auth != null &&
                      request.resource.contentType.matches('image/.*') &&
                      request.resource.size < 10 * 1024 * 1024;
    }
    
    // ==================== SOCIAL POSTS MEDIA ====================
    
    // Post images/videos - أي مستخدم مسجل يمكنه رفع صور للمنشورات
    match /posts/{userId}/{allPaths=**} {
      // Public read
      allow read: if true;
      
      // Authenticated write (owner only)
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      (request.resource.contentType.matches('image/.*') ||
                       request.resource.contentType.matches('video/.*')) &&
                      request.resource.size < 50 * 1024 * 1024; // 50MB for videos
    }
    
    // ==================== DOCUMENTS (PRIVATE) ====================
    
    // Private documents (ID, etc.)
    match /users/{userId}/documents/{allPaths=**} {
      // Owner read only
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Owner write only
      allow write: if request.auth != null && 
                      request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024; // 5MB
    }
    
    // ==================== PUBLIC ASSETS ====================
    
    // Public files
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Admin only via backend
    }
    
    // ==================== DEFAULT DENY ====================
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}