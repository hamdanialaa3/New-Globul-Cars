  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "build:analyze": "npm run build && npx source-map-explorer 'build/static/js/*.js'",
    "build:optimized": "npm run build && node scripts/optimize-images.js",
    "test": "craco test",
    "test:ci": "craco test --watchAll=false --passWithNoTests --coverage",
    "lint": "echo 'Linting disabled - using build for type checking'",
    "eject": "react-scripts eject",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "serve": "firebase serve --only hosting",
    "emulate": "firebase emulators:start"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "jest": {
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@types/react-icons": "^2.2.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "babel-plugin-styled-components": "^2.1.4",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "craco-esbuild": "^0.6.1",
    "crypto-browserify": "^3.12.1",
    "esbuild": "^0.25.11",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-complexity": "^1.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-webpack-plugin": "^4.2.0",
    "firebase-tools": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "process": "^0.11.10",
    "sharp": "^0.34.5",
    "stream-browserify": "^3.0.0",
    "ts-node": "^10.9.2",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "workbox-expiration": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
