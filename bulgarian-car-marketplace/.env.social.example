# Social Media Environment Configuration
# إعدادات البيئة لوسائل التواصل الاجتماعي

# ==========================================
# BULGARIAN CAR MARKETPLACE - SOCIAL MEDIA
# سوق السيارات البلغاري - وسائل التواصل
# ==========================================

# Facebook Integration / تكامل Facebook
# Get these from: https://developers.facebook.com/
REACT_APP_FACEBOOK_APP_ID=your_facebook_app_id_here
REACT_APP_FACEBOOK_APP_SECRET=your_facebook_app_secret_here
REACT_APP_FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here
REACT_APP_FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
REACT_APP_FACEBOOK_AD_ACCOUNT_ID=your_facebook_ad_account_id_here
REACT_APP_FACEBOOK_VERIFY_TOKEN=bulgarian_car_verify_2024
REACT_APP_FACEBOOK_PIXEL_ID=your_facebook_pixel_id_here

# TikTok Integration / تكامل TikTok
# Get these from: https://developers.tiktok.com/
REACT_APP_TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
REACT_APP_TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
REACT_APP_TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
REACT_APP_TIKTOK_APP_ID=your_tiktok_app_id_here

# Instagram Integration / تكامل Instagram
# Get these from: https://developers.facebook.com/ (Instagram Basic Display API)
REACT_APP_INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
REACT_APP_INSTAGRAM_CLIENT_ID=your_instagram_client_id_here
REACT_APP_INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret_here
REACT_APP_INSTAGRAM_APP_ID=your_instagram_app_id_here

# General Social Media Settings / إعدادات وسائل التواصل العامة
REACT_APP_SOCIAL_ENV=development
REACT_APP_DEFAULT_LANGUAGE=bg
REACT_APP_DEFAULT_CURRENCY=EUR
REACT_APP_TIMEZONE=Europe/Sofia

# Bulgarian Localization / الترجمة البلغارية
REACT_APP_BULGARIAN_COUNTRY_CODE=BG
REACT_APP_BULGARIAN_LOCALE=bg-BG

# ==========================================
# SETUP INSTRUCTIONS / تعليمات الإعداد
# ==========================================

# 1. Facebook Setup / إعداد Facebook
# ---------------------------------
# 1. Go to https://developers.facebook.com/
# 2. Create a new app or use existing one
# 3. Add Facebook Login, Graph API, Marketing API products
# 4. Configure app domains: globul.net, localhost (for development)
# 5. Generate access tokens with required permissions:
#    - pages_read_engagement
#    - pages_manage_posts
#    - pages_show_list
#    - ads_read
#    - groups_access_member_info
#    - publish_to_groups

# 2. TikTok Setup / إعداد TikTok
# -----------------------------
# 1. Go to https://developers.tiktok.com/
# 2. Create a developer account
# 3. Create a new app
# 4. Configure app settings:
#    - App URL: https://globul.net
#    - Redirect URI: https://globul.net/auth/tiktok/callback
# 5. Get access token with permissions:
#    - user.info.basic
#    - video.upload
#    - video.list

# 3. Instagram Setup / إعداد Instagram
# -----------------------------------
# 1. Go to https://developers.facebook.com/
# 2. Use the same app as Facebook or create new one
# 3. Add Instagram Basic Display product
# 4. Configure Instagram app:
#    - Instagram App ID
#    - Instagram App Secret
# 5. Get access token with permissions:
#    - user_profile
#    - user_media

# ==========================================
# DEVELOPMENT NOTES / ملاحظات التطوير
# ==========================================

# For local development / للتطوير المحلي:
# - Use localhost:3000 as redirect URI
# - Add localhost to app domains
# - Use test access tokens

# For production / للإنتاج:
# - Use https://globul.net domain
# - Use production access tokens
# - Enable all security features

# Bulgarian-specific settings / الإعدادات البلغارية:
# - Language: Bulgarian (bg) primary, English (en) secondary
# - Currency: EUR (€)
# - Timezone: Europe/Sofia
# - Country: Bulgaria (BG)

# Security reminders / تذكيرات الأمان:
# - Never commit real tokens to version control
# - Use environment-specific tokens
# - Rotate tokens regularly
# - Monitor API usage and limits

# ==========================================
