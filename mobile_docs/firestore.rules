rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 🔴 CRITICAL FIX: Counters collection - Only Cloud Functions can write
    // Numeric ID counters must be protected to prevent corruption
    match /counters/{userId} {
      // ✅ Allow users to read their own counters
      allow read: if isAuthenticated();
      
      // 🔒 HARDENED: Only allow update via strict increment logic, deny direct write/create
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count == resource.data.count + 1;
      
      allow create, delete: if false;
      
      // ✅ Nested car counters per user
      match /cars {
        allow read: if isAuthenticated();
        // Container document - no direct writes
        allow write: if false; 
      }
    }
    
    // ✅ CRITICAL: Car counters document (container)
    match /counters/cars {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    
    // ✅ CRITICAL: Car counters per seller (subcollection under counters/cars document)
    match /counters/cars/sellers/{sellerId} {
      // ✅ Allow any authenticated user to read (needed for transaction.get())
      allow read: if isAuthenticated();
      
      // ✅ Allow users to create their own car counter with initial count = 1
      allow create: if isOwner(sellerId)
        && request.resource.data.keys().hasAll(['count', 'updatedAt'])
        && request.resource.data.count == 1;
      
      // ✅ Allow users to update their own counter with strict increment
      allow update: if isOwner(sellerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['count', 'updatedAt'])
        && request.resource.data.count == resource.data.count + 1;
      
      allow delete: if false;
    }

    // Profiles
    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isOwner(resource.data.userId) 
        || (request.resource.data.userId == request.auth.uid)
        || (isAuthenticated() && request.auth.uid == profileId && request.resource.data.userId == request.auth.uid);
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
    }
    
    // Stripe Customers & Checkout Sessions (Explicit Rule)
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
    }

    // =========================================================================
    // 🚗 VEHICLE COLLECTIONS (HARDENED)
    // Rule: Public Read ONLY if status == 'active'. Owner can read everything.
    // =========================================================================

    // Legacy Support
    match /cars/{carId} {
       allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
       allow write: if false; // 🔒 LOCKED: Legacy
    }
    match /listings/{listingId} {
       allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
       allow write: if false; // 🔒 LOCKED: Legacy
    }

    // Main Collections
    match /passenger_cars/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    match /suvs/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    match /vans/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    match /motorcycles/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    match /trucks/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    match /buses/{carId} { 
      allow read: if resource.data.status == 'active' || isOwner(resource.data.sellerId);
      allow write: if isOwner(resource.data.sellerId) || (request.resource.data.sellerId == request.auth.uid); 
    }
    
    // =========================================================================

    // Follows
    match /follows/{followId} {
      allow read: if isAuthenticated() && (
        followId.matches('^' + request.auth.uid + '_.*') || 
        followId.matches('.*_' + request.auth.uid + '$')
      );
      allow create: if isAuthenticated() 
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followerId != request.resource.data.followingId;
      allow delete: if isAuthenticated() 
        && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // Cloud Functions only
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Favorites
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Saved Searches
    match /savedSearches/{searchId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Chats / Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow delete: if false;
    }
    
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        conversationId.matches('.*' + request.auth.uid + '.*')
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        conversationId.matches('.*' + request.auth.uid + '.*')
      );
      allow delete: if false;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
