{
  "name": "Koli One Development Container",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 5173, 3001, 4000, 5000, 9099, 8080],
  "portsAttributes": {
    "3000": {
      "label": "Web (Vite Dev)",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Web (Vite Alternative)",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Mobile (Expo)",
      "onAutoForward": "notify"
    },
    "4000": {
      "label": "Storybook",
      "onAutoForward": "notify"
    },
    "9099": {
      "label": "Firebase Emulator UI",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Custom Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-azuretools.vscode-cosmosdb",
        "ms-azuretools.azure-databases",
        "ms-azuretools.vscode-docker",
        "GitHub.copilot",
        "ms-playwright.playwright",
        "denoland.vscode-deno",
        "vitest.explorer"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.preferGoToProjectRootOnClick": true,
        "typescript.enablePromptUseWorkspaceTsdk": true
      }
    }
  },
  "remoteEnv": {
    "NODE_ENV": "development",
    "FIREBASE_EMULATOR_HOST": "127.0.0.1:9099"
  },
  "postCreateCommand": "npm install && npm run setup",
  "postStartCommand": "npm run dev:emulators &",
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached"
  ],
  "runArgs": [
    "--network=host"
  ],
  "remoteUser": "node"
}
