rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 🔴 CRITICAL FIX: Counters collection - Only Cloud Functions can write
    // Numeric ID counters must be protected to prevent corruption
    match /counters/{userId} {
      // ✅ Allow users to read their own counters
      allow read: if isAuthenticated();
      
      // ✅ Allow users to write their own counters
      allow write: if isOwner(userId);
      
      // ✅ Nested car counters per user
      match /cars {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }
    
    // ✅ Global users counter (for numeric ID assignment)
    match /counters/users {
      allow read: if true; // Public read OK
      allow update: if isAuthenticated()
        && request.resource.data.count == resource.data.count + 1
        && request.resource.data.keys().hasOnly(['count', 'updatedAt']);
      allow create, delete: if false;
    }

    // Profiles
    match /profiles/{profileId} {
      allow read: if true;
      // ✅ CRITICAL FIX: Allow write if:
      // 1. User owns the profile (userId matches), OR
      // 2. Creating/updating with userId matching auth.uid, OR
      // 3. Updating own profile (profileId == auth.uid) with userId field included
      allow write: if isOwner(resource.data.userId) 
        || (request.resource.data.userId == request.auth.uid)
        || (isAuthenticated() 
            && request.auth.uid == profileId 
            && request.resource.data.userId == request.auth.uid);
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      // ✅ Allow users to update their own data including numericId assignment
      allow write: if isOwner(userId);
      // ✅ Allow updating numericId and related fields
      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['numericId', 'numericIdAssignedAt', 'updatedAt'])
      );
    }
    
    // Stripe Customers & Checkout Sessions (Explicit Rule)
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if request.auth.uid == uid;

      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
    }

    // Cars/Listings
    match /cars/{carId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ✅ NEW: Explicitly allow other vehicle types (Restricted to Owner)
    match /passenger_cars/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    match /suvs/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    match /vans/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    match /motorcycles/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    match /trucks/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    match /buses/{carId} { 
      allow read: if true; 
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid); 
    }
    
    // Legacy support for listings collection if used
    match /listings/{listingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    match /listingMetrics/{metricId} {
       allow read: if true;
       allow write: if isAuthenticated();
    }

    // ==================== FOLLOWS COLLECTION ====================
    // Follow System: User-to-User following relationships
    // Document ID format: {followerId}_{followingId}
    // Security:
    // - Read: If you're the follower or the one being followed
    // - Create: If authenticated and not following yourself
    // - Delete: Only if you're the follower (unfollow your own action)
    match /follows/{followId} {
      // Allow reading if you're involved in the relationship
      allow read: if isAuthenticated() && (
        followId.matches('^' + request.auth.uid + '_.*') ||  // You're the follower
        followId.matches('.*_' + request.auth.uid + '$')     // You're being followed
      );

      // Allow creating a follow if:
      // 1. Authenticated
      // 2. followerId matches your UID
      // 3. Not following yourself (followerId != followingId)
      allow create: if isAuthenticated() 
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followerId != request.resource.data.followingId
        && request.resource.data.keys().hasAll(['followerId', 'followingId', 'createdAt']);

      // Allow deleting only if you're the follower (unfollowing)
      allow delete: if isAuthenticated() 
        && resource.data.followerId == request.auth.uid;

      // No updates allowed (follow/unfollow only)
      allow update: if false;
    }

    // ==================== NOTIFICATIONS COLLECTION ====================
    // Notification System: Real-time alerts for users
    // Security:
    // - Read: Only your own notifications
    // - Create: Only Cloud Functions (deny client writes)
    // - Update: Only to mark as read (isRead field)
    // - Delete: Only your own notifications
    match /notifications/{notificationId} {
      // Read: Only if notification belongs to you
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Create: Deny (only Cloud Functions can create)
      allow create: if false;

      // Update: Only mark as read (isRead field)
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);

      // Delete: Only your own notifications
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // PHASE 3: Team Management (Company Infrastructure)
    // Team Members Sub-collection: users/{companyId}/team_members/{memberId}
    match /users/{companyId}/team_members/{memberId} {
      // Helper: Check if user is the company owner
      function isCompanyOwner() {
        return isAuthenticated() && request.auth.uid == companyId;
      }

      // Helper: Check if user is an active team admin
      function isTeamAdmin() {
        return exists(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId))
          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.linkedUserId == request.auth.uid
          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.role == 'admin'
          && get(/databases/$(database)/documents/users/$(companyId)/team_members/$(memberId)).data.status == 'active';
      }

      // Read: Company owner or active team members
      allow read: if isCompanyOwner() || isTeamAdmin();

      // Create/Update/Delete: Only company owner or team admins
      allow create, update, delete: if isCompanyOwner() || isTeamAdmin();
    }

    // Team Invitations Collection: team_invitations/{inviteId}
    match /team_invitations/{inviteId} {
      // Read: Any authenticated user (to check invite codes)
      allow read: if isAuthenticated();

      // Create: Only company owners
      allow create: if isAuthenticated() && request.resource.data.companyId == request.auth.uid;

      // Update: Only invitation owner (to revoke/accept)
      allow update: if isAuthenticated() && resource.data.companyId == request.auth.uid;

      // Delete: Only invitation owner
      allow delete: if isAuthenticated() && resource.data.companyId == request.auth.uid;
    }

    // ==================== ANALYTICS COLLECTIONS ====================
    // Search Analytics: Track search queries and clicks
    match /searchAnalytics/{analyticsId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anonymous search tracking
      allow update: if isAuthenticated();
      allow delete: if false; // No deletes
    }

    match /searchClicks/{clickId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anonymous click tracking
      allow update: if false; // No updates
      allow delete: if false; // No deletes
    }

    match /searchAggregates/{aggregateId} {
      allow read: if true; // Public read for popular searches
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ==================== CAMPAIGNS COLLECTION ====================
    // Marketing Campaigns
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== CONSULTATIONS COLLECTION ====================
    // Expert Consultations
    match /consultations/{consultationId} {
      allow read: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.expertId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.expertId == request.auth.uid
      );
      allow delete: if isAuthenticated() && resource.data.requesterId == request.auth.uid;
    }

    // ==================== REVIEWS COLLECTION ====================
    // Post-Sale Reviews
    match /reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.buyerId == request.auth.uid;
      allow delete: if false; // No review deletion (admin only via backend)
    }

    // ==================== CAR STORIES COLLECTION ====================
    // User Car Stories and Experience
    // Document ID: userId (one story per user)
    // Security:
    // - Read: Public (anyone can read car stories)
    // - Write: Only owner can create/update their story
    match /carStories/{userId} {
      allow read: if true; // Public read for all car stories
      allow write: if isOwner(userId); // Only owner can edit their story
    }

    // ==================== INTRO VIDEOS COLLECTION ====================
    // User Introduction Videos
    // Document ID: userId (one video per user)
    // Security:
    // - Read: Public (showcase videos)
    // - Write: Only owner can manage their video
    match /introVideos/{userId} {
      allow read: if true; // Public read
      allow write: if isOwner(userId); // Owner only
    }

    // ==================== SUCCESS STORIES COLLECTION ====================
    // User Success Stories and Achievements
    // Security:
    // - Read: Public (inspirational stories)
    // - Create: Authenticated users
    // - Update/Delete: Only owner
    match /successStories/{storyId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== AVAILABILITY CALENDARS COLLECTION ====================
    // User Availability for Appointments
    // Document ID: userId (one calendar per user)
    // Security:
    // - Read: Public (anyone can see availability)
    // - Write: Only owner can manage their calendar
    match /availabilityCalendars/{userId} {
      allow read: if true; // Public read for booking
      allow write: if isOwner(userId); // Owner only
    }

    // ==================== ACHIEVEMENTS COLLECTION ====================
    // User Achievements, Badges, and Certificates
    // Security:
    // - Read: Public (showcase achievements)
    // - Write: Only owner or admin (badges awarded by system)
    match /achievements/{achievementId} {
      allow read: if true; // Public read
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== DRAFTS COLLECTION ====================
    // Car Listing Drafts
    // Security: Only owner can access their drafts
    match /drafts/{draftId} {
      // ✅ FIX: Allow read if authenticated and draftId starts with userId
      // Pattern: drafts are stored as {userId}_{timestamp} or similar
      allow read: if isAuthenticated();
      
      // ✅ FIX: Allow write operations if authenticated
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if isAuthenticated() 
        && (resource.data.userId == request.auth.uid 
            || request.resource.data.userId == request.auth.uid);
    }

    // ==================== EVENTS COLLECTION ====================
    // Community Events
    // Security:
    // - Read: Public
    // - Create: Authenticated users
    // - Update/Delete: Owner only
    match /events/{eventId} {
      allow read: if true; // Public events
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && resource.data.organizerId == request.auth.uid;
    }

    // ==================== EVENT RSVPs COLLECTION ====================
    // Event Attendance Tracking
    match /eventRSVPs/{rsvpId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== LEADERBOARDS COLLECTION ====================
    // User Rankings and Scores
    // Security: Public read, system writes only
    match /leaderboards/{userId} {
      allow read: if true; // Public leaderboard
      allow write: if false; // System/Cloud Functions only
    }

    // ==================== SAVED SEARCHES COLLECTION ====================
    // User Saved Search Filters
    match /savedSearches/{searchId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // ==================== SOCIAL MEDIA ACCOUNTS COLLECTION ====================
    // Linked Social Media Profiles
    // Document ID: userId
    match /socialMediaAccounts/{userId} {
      allow read: if true; // Public profiles
      allow write: if isOwner(userId); // Owner only
    }

    // ==================== TRANSACTIONS COLLECTION ====================
    // Financial Transactions
    // Security: Strict owner-only access
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // No modifications (audit trail)
    }

    // ==================== TRUST CONNECTIONS COLLECTION ====================
    // Trust Network Relationships
    match /trustConnections/{connectionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.requesterId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isAuthenticated() && resource.data.requesterId == request.auth.uid;
    }

    // ==================== WORKFLOW ANALYTICS COLLECTION ====================
    // System Analytics (Admin/Cloud Functions)
    match /workflow_analytics/{analyticsId} {
      allow read: if isAuthenticated(); // Users can read aggregate stats
      allow write: if false; // System only
    }

    // ==================== DEALERSHIPS COLLECTION ====================
    // Verified Dealerships/Companies
    match /dealerships/{dealershipId} {
      allow read: if true; // Public read for all verified dealerships
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if false; // No deletion (admin only via backend)
    }

    // ==================== POSTS COLLECTION (Social Feed) ====================
    // Community Posts
    match /posts/{postId} {
      allow read: if true; // Public posts visible to everyone
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Comments sub-collection
      match /comments/{commentId} {
        allow read: if true; // Public comments
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      }

      // Likes sub-collection
      match /likes/{likeId} {
        allow read: if true; // Public likes count
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow update: if false; // No updates to likes
      }
    }

    // ==================== FAVORITES COLLECTION ====================
    // User Favorites (saved cars)
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false; // No updates to favorites
    }

    // 🔴 CRITICAL: Blocked Users Collection (January 2026 - User Safety)
    // Block relationships between users
    match /blocked_users/{blockId} {
      // Read: Only if you're involved in the block relationship
      allow read: if isAuthenticated() && (
        resource.data.blockerFirebaseId == request.auth.uid ||
        resource.data.blockedFirebaseId == request.auth.uid
      );

      // Create: Only if you're the blocker (can't block on behalf of others)
      allow create: if isAuthenticated() 
        && request.resource.data.blockerFirebaseId == request.auth.uid
        && request.resource.data.blockerFirebaseId != request.resource.data.blockedFirebaseId // Can't block yourself
        && request.resource.data.keys().hasAll(['blockerNumericId', 'blockerFirebaseId', 'blockedNumericId', 'blockedFirebaseId', 'createdAt', 'updatedAt']);

      // Update: Only if you're the blocker (can update reason)
      allow update: if isAuthenticated() 
        && resource.data.blockerFirebaseId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reason', 'updatedAt']);

      // Delete: Only if you're the blocker (can unblock)
      allow delete: if isAuthenticated() && resource.data.blockerFirebaseId == request.auth.uid;
    }

    // 🔴 CRITICAL: Reports Collection (January 2026 - Content Moderation)
    // User reports for spam, abuse, fake content
    match /reports/{reportId} {
      // Read: Only if you're the reporter (users can see their own reports)
      allow read: if isAuthenticated() && resource.data.reporterFirebaseId == request.auth.uid;

      // Create: Only authenticated users can create reports
      allow create: if isAuthenticated()
        && request.resource.data.reporterFirebaseId == request.auth.uid
        && request.resource.data.reporterFirebaseId != request.resource.data.reportedUserFirebaseId // Can't report yourself
        && request.resource.data.keys().hasAll(['reporterFirebaseId', 'reporterNumericId', 'reportedUserFirebaseId', 'reportedUserNumericId', 'reportType', 'contentType', 'reason', 'description', 'status', 'createdAt', 'updatedAt']);

      // Update: Only admins can update reports (via Cloud Functions)
      allow update: if false; // Only Cloud Functions can update

      // Delete: No deletes (archival only)
      allow delete: if false;
    }

    // ==================== MESSAGES & CONVERSATIONS ====================
    // Direct Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow delete: if false; // No message deletion
    }

    // Conversations metadata
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (
        conversationId.matches('.*' + request.auth.uid + '.*')
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        conversationId.matches('.*' + request.auth.uid + '.*')
      );
      allow delete: if false; // No conversation deletion
    }

    // ==================== ANALYTICS EVENTS & METRICS ====================
    // Profile Analytics: Track profile views, car views, inquiries
    match /analytics_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anonymous tracking
      allow update: if false; // No updates
      allow delete: if false; // No deletes
    }

    match /profile_analytics/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    match /profile_metrics/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if true; // System creates
      allow update: if true; // System updates metrics
      allow delete: if false;
    }

    // ==================== USER POINTS & LEVELS ====================
    match /userPoints/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if true; // System creates
      allow update: if true; // System updates points
      allow delete: if false;
    }

    // ==================== PROFILE STATS ====================
    match /profile_stats/{statsId} {
      allow read: if isAuthenticated();
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    match /profiles/{profileId} {
      allow read: if true;
      allow write: if isOwner(resource.data.userId) || (request.resource.data.userId == request.auth.uid);
    }

    // ==================== SAVED SEARCHES ====================
    match /saved_searches/{searchId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== LISTING REVIEWS ====================
    match /listing_reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // ==================== SEARCH ANALYTICS ====================
    match /searchAnalytics/{analyticsId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anonymous
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    match /searchClicks/{clickId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anonymous
      allow update: if false;
      allow delete: if false;
    }

    // ==================== LEADERBOARD ====================
    match /leaderboard/{entryId} {
      allow read: if true; // Public leaderboard
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    // ==================== CHALLENGES ====================
    // Monthly Challenges System
    match /challenges/{challengeId} {
      allow read: if true; // Public challenges
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // Monthly Challenges (New Collection Name)
    match /monthlyChallenges/{challengeId} {
      allow read: if true; // Public challenges
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    // User Challenge Progress (Old Collection Name)
    match /user_challenges/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // User Challenge Progress (New Collection Name)
    match /userChallengeProgress/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== STORIES ====================
    match /stories/{storyId} {
      allow read: if true; // Public stories
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== ACHIEVEMENTS ====================
    match /achievements/{achievementId} {
      allow read: if true; // Public achievements
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    match /user_achievements/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    // ==================== BADGES ====================
    match /badges/{badgeId} {
      allow read: if true; // Public badges
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    match /user_badges/{entryId} {
      allow read: if true; // Public user badges
      allow create: if true; // System creates
      allow update: if true; // System updates
      allow delete: if false;
    }

    // ==================== SEARCH HISTORY ====================
    match /searchHistory/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ==================== USER GROUPS & MEMBERSHIPS ====================
    // User Groups (Community Feature)
    match /userGroups/{groupId} {
      // Allow reading groups (public groups or browsing)
      allow read: if true;
      // Allow creating groups if authenticated
      allow create: if isAuthenticated();
      // Allow updates if authenticated (ideally restricted to group admins)
      allow update: if isAuthenticated();
      // Delete not allowed (archive instead)
      allow delete: if false;
    }

    // Group Memberships
    match /groupMemberships/{membershipId} {
      // Allow reading memberships to check status (Public for profile views)
      // Required for getUserMemberships query on public profiles
      allow read: if true;
      
      // Allow joining (creating membership) for yourself
      allow create: if isAuthenticated() 
        && request.resource.data.userId == request.auth.uid;
        
      // Allow updating own membership (e.g., settings)
      allow update: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
        
      // Allow leaving (deleting membership)
      allow delete: if isAuthenticated() 
        && resource.data.userId == request.auth.uid;
    }

    // General fallback (deny by default, but opened for dev/debugging if needed - keep strict for now)
    // Default: Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
