rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Validate profile type (Phase 0 Day 4)
    function isValidProfileType(profileType) {
      return profileType in ['private', 'dealer', 'company'];
    }
    
    // Validate plan tier (Phase 0 Day 4)
    function isValidPlanTier(tier) {
      return tier in ['free', 'dealer', 'company'];
    }
    
    // Check if plan tier matches profile type (Phase 0 Day 4)
    function planTierMatchesProfileType(profileType, planTier) {
      return (profileType == 'private' && planTier == 'free') ||
             (profileType == 'dealer' && planTier == 'dealer') ||
             (profileType == 'company' && planTier == 'company');
    }
    
    // Validate dealer profile requirements (Phase 0 Day 4)
    function hasDealerRequirements(data) {
      return data.dealershipRef is string && 
             data.dealershipRef.matches('dealerships/.*') &&
             data.dealerSnapshot is map;
    }
    
    // Validate company profile requirements (Phase 0 Day 4)
    function hasCompanyRequirements(data) {
      return data.companyRef is string && 
             data.companyRef.matches('companies/.*') &&
             data.companySnapshot is map;
    }
    
    // ==================== USERS COLLECTION ====================
    
    // Helper function to check if profile is public
    // Profiles are public by default unless explicitly set to 'private'
    function isProfilePublic(profileData) {
      return !('profileVisibility' in profileData) || 
             profileData.profileVisibility == 'public' ||
             profileData.profileVisibility == null;
    }
    
    match /users/{userId} {
      // SECURITY FIX: Restrict user data access
      // Allow read if:
      // 1. User is reading their own profile (full access)
      // 2. User is admin (full access for moderation)
      // 3. Profile is public (limited access - sensitive fields filtered in frontend)
      // 
      // Note: Sensitive fields (email, phoneNumber) should be filtered in frontend
      // using sanitizeUserForDisplay() from users-directory.service.ts
      allow read: if isAuthenticated() && 
                     (request.auth.uid == userId || // Own profile - full access
                      isAdmin() || // Admin - full access for moderation
                      isProfilePublic(resource.data)); // Public profile - frontend will filter sensitive data
      
      // Allow create if:
      // - User is creating their own profile
      // - Required fields are present
      allow create: if isAuthenticated() && 
                       request.auth.uid == userId &&
                       request.resource.data.email is string &&
                       request.resource.data.displayName is string &&
                       isValidProfileType(request.resource.data.profileType) &&
                       request.resource.data.profileType == 'private'; // New users default to private
      
      // Allow update if:
      // - User owns the profile OR is admin
      // - Profile type changes are validated (Phase 0 Day 4)
      allow update: if (isOwner(userId) || isAdmin()) &&
                       // Validate profileType if being changed
                       (!('profileType' in request.resource.data) || 
                        (isValidProfileType(request.resource.data.profileType) &&
                         validateProfileTypeChange(
                           resource.data.get('profileType', 'private'),
                           request.resource.data.profileType,
                           request.resource.data
                         )));
      
      // Allow delete only by admin
      allow delete: if isAdmin();
      
      // Validate profile type change (Phase 0 Day 4)
      function validateProfileTypeChange(oldType, newType, newData) {
        return newType == oldType || // No change
               (newType == 'private') || // Downgrade to private always allowed
               (newType == 'dealer' && hasDealerRequirements(newData)) || // Upgrade to dealer with requirements
               (newType == 'company' && hasCompanyRequirements(newData)); // Upgrade to company with requirements
      }
      
      // Followers subcollection
      match /followers/{followerId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
      
      // Following subcollection
      match /following/{followingId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }
    
    // ==================== DEALERSHIPS COLLECTION ====================
    
    match /dealerships/{dealershipId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create/update if:
      // - User owns the dealership OR is admin
      // - User's profile is 'dealer' type
      allow create, update: if (isOwner(dealershipId) || isAdmin()) &&
                               // Verify user is dealer type
                               get(/databases/$(database)/documents/users/$(dealershipId)).data.profileType == 'dealer';
      
      // Allow delete only by admin
      allow delete: if isAdmin();
    }

    // ==================== COMPANIES COLLECTION ====================
    
    match /companies/{companyId} {
      // Allow read if authenticated
      allow read: if isAuthenticated();
      
      // Allow create/update if:
      // - User owns the company OR is admin
      // - User's profile is 'company' type
      allow create, update: if (isOwner(companyId) || isAdmin()) &&
                               // Verify user is company type
                               get(/databases/$(database)/documents/users/$(companyId)).data.profileType == 'company';
      
      // Allow delete only by admin
      allow delete: if isAdmin();
    }
    
    // ==================== CARS COLLECTION ====================
    
    match /cars/{carId} {
      // Allow public read for ACTIVE listings only (security improvement)
      // This enables homepage sections to display cars without login
      // Public visibility: status == 'active' AND isActive == true AND not sold
      allow read: if resource.data.status == 'active' 
                  && resource.data.isActive == true
                  && !(resource.data.isSold == true);
      
      // Allow authenticated users to read their own listings (even if inactive)
      allow read: if isAuthenticated() && 
                     resource.data.sellerId == request.auth.uid;
      
      // Allow admins to read all listings
      allow read: if isAdmin();
      
      // Allow create if authenticated and listing limit not exceeded
      // Validates:
      // 1. sellerId field exists and is string
      // 2. sellerId matches authenticated user
      // 3. sellerEmail matches authenticated user's email
      // 4. status must be 'active' and isActive must be true for new listings
      // 5. Listing limits based on plan tier
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId is string &&
                       request.resource.data.sellerId == request.auth.uid &&
                       request.resource.data.sellerEmail == request.auth.token.email &&
                       request.resource.data.status == 'active' &&
                       request.resource.data.isActive == true &&
                       // Check listing limits based on plan tier
                       canAddListing(request.auth.uid);
      
      // Allow update if owner or admin
      // Prevents changing sellerId (ownership transfer protection)
      allow update: if (isOwner(resource.data.sellerId) || isAdmin()) &&
                       // Prevent changing sellerId
                       (!('sellerId' in request.resource.data.diff(resource.data)) ||
                        request.resource.data.sellerId == resource.data.sellerId);
      
      // Allow delete if owner or admin
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
      
      // Check if user can add more listings (Phase 0 Day 4)
      function canAddListing(userId) {
        let userDoc = get(/databases/$(database)/documents/users/$(userId));
        let activeListings = userDoc.data.get('stats', {}).get('activeListings', 0);
        let planTier = userDoc.data.get('plan', {}).get('tier', 'free');
        
        // Listing limits by plan tier
        return (planTier == 'free' && activeListings < 3) ||
               (planTier == 'premium' && activeListings < 10) ||
               (planTier == 'dealer_basic' && activeListings < 50) ||
               (planTier == 'dealer_pro' && activeListings < 150) ||
               (planTier in ['dealer_enterprise', 'company_pro', 'company_enterprise']) || // Unlimited
               (planTier == 'company_starter' && activeListings < 100);
      }
      
      // AI processing logs subcollection (Cloud Functions only)
      match /ai_logs/{logId} {
        allow read: if isAdmin();
        allow write: if false; // Only Cloud Functions
      }
    }
    
    // ==================== NEW VEHICLE COLLECTIONS ====================
    // Rules for new vehicle type collections (Dec 2025)
    // Collections: passenger_cars, suvs, vans, motorcycles, trucks, buses
    
    match /passenger_cars/{carId} {
      allow read: if true; // Public read for all cars
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /suvs/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /vans/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /motorcycles/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /trucks/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    match /buses/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && 
                               (resource.data.sellerId == request.auth.uid || isAdmin());
    }
    
    // ==================== POSTS COLLECTION ====================
    
    match /posts/{postId} {
      // Allow read to all authenticated users (or public posts)
      allow read: if isAuthenticated() || 
                     resource.data.visibility == 'public';
      
      // Allow create if authenticated and authorId matches
      allow create: if isAuthenticated() &&
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.authorId is string &&
                       request.resource.data.status == 'published';
      
      // Allow update if owner or admin
      allow update: if isAuthenticated() && 
                       (resource.data.authorId == request.auth.uid || isAdmin()) &&
                       // Prevent changing authorId
                       (!('authorId' in request.resource.data.diff(resource.data)));
      
      // Allow delete if owner or admin
      allow delete: if isAuthenticated() && 
                       (resource.data.authorId == request.auth.uid || isAdmin());
      
      // ==================== COMMENTS SUBCOLLECTION ====================
      
      match /comments/{commentId} {
        // Allow read to all authenticated users
        allow read: if isAuthenticated();
        
        // Allow create if authenticated
        allow create: if isAuthenticated() && 
                         request.resource.data.authorId == request.auth.uid &&
                         request.resource.data.postId == postId &&
                         request.resource.data.status == 'active';
        
        // Allow update if owner (for editing)
        allow update: if isAuthenticated() && 
                         resource.data.authorId == request.auth.uid &&
                         // Only allow status/content updates
                         (!('authorId' in request.resource.data.diff(resource.data)) &&
                          !('postId' in request.resource.data.diff(resource.data)));
        
        // Allow delete if owner or admin
        allow delete: if isAuthenticated() && 
                         (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }
    
    // ==================== MESSAGES COLLECTION ====================
    
    // ChatRooms collection (for real-time messaging)
    match /chatRooms/{chatRoomId} {
      // Allow read if user is participant
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.participants;
      
      // Allow create if user is one of the participants
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.participants;
      
      // Allow update if user is participant (for read status, etc.)
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;
      
      // Allow delete if user is participant
      allow delete: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;
    }
    
    match /conversations/{conversationId} {
      // Allow read if user is participant
      allow read: if isAuthenticated() &&
                     request.auth.uid in resource.data.participants;
      
      // Allow create if user is one of the participants
      allow create: if isAuthenticated() &&
                       request.auth.uid in request.resource.data.participants;
      
      // Allow update if user is participant (for read status, etc.)
      allow update: if isAuthenticated() &&
                       request.auth.uid in resource.data.participants;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                       request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        
        allow create: if isAuthenticated() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
    
    // ==================== ANALYTICS COLLECTION ====================
    
    match /analytics/{userId} {
      // Only owner or admin can read analytics
      allow read: if isOwner(userId) || isAdmin();
      
      // System can write (Cloud Functions)
      allow write: if false; // Only Cloud Functions
    }
    
    // ==================== STRIPE PAYMENTS EXTENSION ====================
    // Rules for invertase/firestore-stripe-payments extension
    
    // Customer data (subscriptions, payments, checkout sessions)
    match /customers/{uid} {
      // Users can only read their own customer data
      allow read: if isOwner(uid);

      // Checkout sessions - users can create and read their own sessions
      match /checkout_sessions/{id} {
        allow read, write: if isOwner(uid);
      }
      
      // Subscriptions - users can only read their own subscriptions
      match /subscriptions/{id} {
        allow read: if isOwner(uid);
      }
      
      // Payments - users can only read their own payment records
      match /payments/{id} {
        allow read: if isOwner(uid);
      }
    }

    // Products and prices - publicly readable for all users
    match /products/{id} {
      allow read: if true;
      allow write: if false; // Only Stripe webhook can write

      match /prices/{id} {
        allow read: if true;
        allow write: if false; // Only Stripe webhook can write
      }

      match /tax_rates/{id} {
        allow read: if true;
        allow write: if false; // Only Stripe webhook can write
      }
    }
    
    // ==================== PROFILE ENHANCEMENTS - PHASE 1 ====================
    
    // Success Stories
    match /successStories/{storyId} {
      // Users can read public stories or their own stories
      allow read: if resource.data.isPublic == true || 
                     (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Users can create their own stories
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update/delete their own stories
      allow update, delete: if isAuthenticated() && 
                               resource.data.userId == request.auth.uid;
    }
    
    // Trust Connections
    match /trustConnections/{connectionId} {
      // Users can read connections where they are involved
      allow read: if isAuthenticated() && 
                     (resource.data.fromUserId == request.auth.uid || 
                      resource.data.toUserId == request.auth.uid);
      
      // Users can create connections from themselves
      allow create: if isAuthenticated() && 
                       request.resource.data.fromUserId == request.auth.uid;
      
      // Users can update connections where they are the recipient
      allow update: if isAuthenticated() && 
                       resource.data.toUserId == request.auth.uid;
      
      // Users can delete their own outgoing connections
      allow delete: if isAuthenticated() && 
                       resource.data.fromUserId == request.auth.uid;
    }
    
    // Car Stories
    match /carStories/{userId} {
      // Anyone can read car stories (public profile feature)
      allow read: if true;
      
      // Users can create/update their own car story
      allow write: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
    }
    
    // User Points
    match /userPoints/{userId} {
      // Users can read their own points, or any authenticated user can read any points (for leaderboard)
      allow read: if isAuthenticated();
      
      // Users can create their own initial userPoints document
      allow create: if isAuthenticated() && userId == request.auth.uid;
      
      // Only server/admin can update/delete (via Cloud Functions)
      allow update, delete: if isAdmin();
    }
    
    // ==================== PROFILE ENHANCEMENTS - PHASE 2 ====================
    
    // User Groups
    match /userGroups/{groupId} {
      // Anyone can read public groups
      allow read: if resource.data.isPublic == true;
      
      // Authenticated users can read all groups (for browsing)
      allow read: if isAuthenticated();
      
      // Only admins can create groups
      allow create: if isAdmin();
      
      // Only admins can update/delete groups
      allow update, delete: if isAdmin();
    }
    
    // Group Memberships
    match /groupMemberships/{membershipId} {
      // Users can read their own memberships
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can read memberships for groups they're in (for member list)
      allow read: if isAuthenticated();
      
      // Users can join groups (create membership)
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can leave groups (delete their own membership)
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Only group admins/moderators can update (for role changes)
      allow update: if isAdmin();
    }
    
    // Monthly Challenges
    match /monthlyChallenges/{challengeId} {
      // Anyone authenticated can read all challenges (active or inactive)
      allow read: if isAuthenticated();
      
      // Only admins can create/update challenges
      allow create, update, delete: if isAdmin();
    }
    
    // User Challenge Progress
    match /userChallengeProgress/{progressId} {
      // Users can read their own progress
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create their own progress
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update their own progress
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // System can update progress (via Cloud Functions)
      allow update: if isAdmin();
    }
    
    // Transactions
    match /transactions/{transactionId} {
      // Users can read their own transactions
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create transactions for their own sales
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update their own transactions (e.g., status, notes)
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Users cannot delete transactions (for audit trail)
      allow delete: if false;
    }
    
    // Availability Calendars
    match /availabilityCalendars/{userId} {
      // Anyone can read availability (for scheduling)
      allow read: if true;
      
      // Users can create/update their own calendar
      allow write: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
    }
    
    // ==================== PROFILE ENHANCEMENTS - PHASE 3 ====================
    
    // Intro Videos
    match /introVideos/{userId} {
      // Anyone authenticated can read videos (for profile viewing)
      allow read: if isAuthenticated();
      
      // Users can create/update their own video
      allow write: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid;
      
      // Users can delete their own video
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Leaderboards
    match /leaderboards/{leaderboardId} {
      // Anyone can read leaderboards
      allow read: if true;
      
      // Only system can write (via Cloud Functions)
      allow write: if isAdmin();
    }
    
    // Leaderboard Ranks
    match /leaderboardRanks/{rankId} {
      // Users can read their own ranks
      allow read: if isAuthenticated();
      
      // Only system can write (via Cloud Functions)
      allow write: if isAdmin();
    }
    
    // Achievements
    match /achievements/{achievementId} {
      // Anyone authenticated can read achievements (for achievement galleries)
      allow read: if isAuthenticated();
      
      // Users can create their own achievements
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update visibility of their own achievements
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       !('userId' in request.resource.data.diff(resource.data)) &&
                       !('type' in request.resource.data.diff(resource.data)) &&
                       !('unlockedAt' in request.resource.data.diff(resource.data));
      
      // Only system can delete (for cleanup)
      allow delete: if isAdmin();
    }
    
    // Achievement Certificates
    match /achievementCertificates/{certificateId} {
      // Users can read their own certificates
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create their own certificates
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Only admins can verify certificates
      allow update: if isAdmin();
      
      // Users can delete their own certificates
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // ==================== PERSONAL VEHICLES - Mobile.de Style ====================
    
    // User Personal Vehicles
    match /userVehicles/{vehicleId} {
      // Users can read their own vehicles
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create their own vehicles
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.make is string &&
                       request.resource.data.model is string &&
                       request.resource.data.currentMileage is number &&
                       request.resource.data.postalCode is string;
      
      // Users can update their own vehicles
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       !('userId' in request.resource.data.diff(resource.data)) &&
                       !('id' in request.resource.data.diff(resource.data));
      
      // Users can delete their own vehicles
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Vehicle Reminders
    match /vehicleReminders/{reminderId} {
      // Users can read their own reminders
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create their own reminders
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.vehicleId is string &&
                       request.resource.data.type is string &&
                       request.resource.data.dueDate is timestamp;
      
      // Users can update their own reminders
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       !('userId' in request.resource.data.diff(resource.data)) &&
                       !('vehicleId' in request.resource.data.diff(resource.data));
      
      // Users can delete their own reminders
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Saved Searches
    match /savedSearches/{searchId} {
      // Users can read their own saved searches
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Users can create their own saved searches
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update their own saved searches
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid &&
                       !('userId' in request.resource.data.diff(resource.data));
      
      // Users can delete their own saved searches
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // ==================== DEFAULT DENY ====================
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
