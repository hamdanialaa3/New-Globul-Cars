rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPERS & FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if user is admin or super_admin (via admins/super_admins collection)
    function isAdmin() {
      return (
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true
        ) || (
          exists(/databases/$(database)/documents/super_admins/$(request.auth.uid))
        ) || (
          request.auth.token.admin == true
        )
      );
    }

    // Validate document size to prevent abuse (max 1MB equivalent ~500 fields)
    function isReasonableSize() {
      return request.resource.data.keys().size() < 500;
    }
    
    // Ensure VIN Verification Cannot be Tampered
    function isVinVerificationSecure() {
      return !('vinVerification' in request.resource.data) 
        || (resource != null && request.resource.data.vinVerification == resource.data.vinVerification)
        || isAdmin();
    }
    
    // ============================================
    // USERS Collection
    // ============================================
    match /users/{userId} {
      // Anyone can read basic user profiles (needed for seller avatar, display name, etc.)
      // Sensitive auth data lives in Firebase Auth, not Firestore — this is safe.
      allow read: if true;
      // Allow create for both regular and anonymous Firebase Auth users.
      // Anonymous users have no email, so we only require 'createdAt'.
      allow create: if isAuthenticated() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['createdAt']);
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role); // Users can't change their own role
      allow delete: if isAdmin();
      
      // For nested user documents (private by default — only owner/admin)
      match /{document=**} {
        allow read: if isAuthenticated() && (
          isOwner(userId) ||
          isAdmin()
        );
        allow write: if isOwner(userId);
      }
    }
    
    // ============================================
    // GARAGE VEHICLES Collection (Smart Digital Garage)
    // 🔒 SECURED: Users can only read, write, and delete their own vehicles.
    // ============================================
    match /garage_vehicles/{vehicleId} {
      allow read: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerUid == request.auth.uid;
    }

    // ============================================
    // AUCTION LISTINGS Collection (Koli.one Reverse Bidding)
    // 🔒 SECURED: Anyone can read, but only Dealers/Admins can bid. Sellers create.
    // ============================================
    match /auction_listings/{auctionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      // Only the backend/transaction or the seller can update basic details
      allow update: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid ||
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pricing', 'timing', 'bidsCount', 'updatedAt'])) // Allowed for transactions
      );
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.sellerId == request.auth.uid);

      match /bids/{bidId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.bidderId == request.auth.uid;
        allow update, delete: if false; // Bids are immutable
      }
    }

    // ============================================
    // APP SETTINGS Collection
    // ============================================
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // CARS Collection (Listings) - Legacy
    // ============================================
    match /cars/{carId} {
      // Anyone can read active/published cars
      allow read: if true;
      
      // Sellers can create cars — must own listing
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId;
      
      // Only seller can update their own listing
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      
      // Only seller or admin can delete
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // VEHICLE COLLECTIONS (All Vehicle Types)
    // 🔒 SECURED: All vehicle types enforce sellerId ownership
    // ============================================
    match /passenger_cars/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && isVinVerificationSecure();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid && isVinVerificationSecure();
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /suvs/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /vans/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /motorcycles/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /trucks/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /buses/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /construction_machines/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /agricultural_machines/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /trailers/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /campers/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /forklifts/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /boats/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.keys().hasAll(['sellerId', 'make', 'model', 'price', 'createdAt'])
        && request.resource.data.price is number
        && request.resource.data.price > 0;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /listings/{carId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // WORKFLOW Collections (Drafts, Progress, Images)
    // 🔒 SECURED: Owner-only write (was: any authenticated user)
    // ============================================
    match /workflow_drafts/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }
    
    match /workflow_progress/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }
    
    match /workflow_images/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
    }
    
    // ============================================
    // DEALERSHIPS Collection
    // 🔒 SECURED: Owner-only create/update
    // ============================================
    match /dealerships/{dealershipId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // POSTS Collection (Social Feed)
    // 🔒 SECURED: Owner-only create/update
    // ============================================
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid || isAdmin()
        );
      }
    }
    
    // ============================================
    // STORIES Collection
    // 🔒 SECURED: Owner-only create/update
    // ============================================
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // REVIEWS Collection
    // ============================================
    match /reviews/{reviewId} {
      allow read: if resource.data.published == true 
        || resource.data.status == 'approved'
        || (isAuthenticated() && resource.data.reviewerId == request.auth.uid)
        || isAdmin();
      
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.reviewerId
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.keys().hasAll(['reviewerId', 'rating', 'createdAt'])
        // Anti-fraud: cannot review yourself
        && (
          !request.resource.data.keys().hasAny(['targetUserId']) 
          || request.auth.uid != request.resource.data.targetUserId
        );
      
      allow update: if isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid || isAdmin()
      );
      
      allow delete: if isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // MESSAGES Collection (Chat)
    // ============================================
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.keys().hasAll(['senderId', 'receiverId', 'text', 'createdAt']);
      
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      
      allow delete: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }
    
    // ============================================
    // PROMOTIONS Collection
    // ============================================
    match /promotions/{promotionId} {
      allow read: if isAuthenticated() && isAdmin();
      allow write: if isAuthenticated() && isAdmin();
    }

    // ============================================
    // FAVORITES Collection
    // ============================================
    match /favorites/{document=**} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         request.query.userId == request.auth.uid);
      
      allow write: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // ANALYTICS Collection (Read-only aggregates)
    // ============================================
    match /analytics/{document=**} {
      allow read: if true;
      allow write: if false; // Use Cloud Functions for writes
    }
    
    // ============================================
    // ADMIN Collection
    // ============================================
    match /admins/{userId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // TRANSACTIONS Collection
    // 🔒 SECURED: Cloud Functions only — no client writes
    // ============================================
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if false;
    }
    
    // ============================================
    // REPORTS — Authenticated users can create reports
    // ============================================
    match /reports/{reportId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        resource.data.reporterId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.keys().hasAll(['listingId', 'reason', 'reporterId', 'status']);
      allow update, delete: if request.auth.token.admin == true;
    }

    // ============================================
    // DEALER APPLICATIONS — Auth users can apply
    // ============================================
    match /dealer_applications/{appId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.token.admin == true;
    }

    // ============================================
    // CAMPAIGNS — Owner CRUD
    // ============================================
    match /campaigns/{campaignId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.admin == true
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================
    // CONSULTATION REQUESTS — Owner read/create
    // ============================================
    match /consultation_requests/{reqId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.admin == true
      );
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.token.admin == true;
    }

    // ============================================
    // SOCIAL POSTS — Owner write, public read
    // 🔒 SECURED: Owner-only create/update
    // ============================================
    match /social_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================
    // USER FOLLOWING — Owner only
    // ============================================
    match /users/{userId}/following/{targetId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ============================================
    // NOTIFICATIONS Collection (User notifications)
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if false; // Cloud Functions only
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // ============================================
    // ADMIN NOTIFICATIONS Collection
    // ============================================
    match /admin_notifications/{notificationId} {
      allow read, write: if isAuthenticated() && isAdmin();
    }

    // ============================================
    // CUSTOMERS Collection (Stripe subscriptions)
    // ============================================
    match /customers/{customerId} {
      allow read: if isAuthenticated() && isOwner(customerId);
      allow write: if false; // Managed by Stripe extension
      
      match /{document=**} {
        allow read: if isAuthenticated() && isOwner(customerId);
        allow write: if false;
      }
    }

    // ============================================
    // ANALYTICS EVENTS Collection (car views, profile views, etc.)
    // 🔒 SECURED: Rate-limit via data size check, immutable after creation
    // ============================================
    match /analytics_events/{eventId} {
      allow create: if isAuthenticated() && isReasonableSize() && request.resource.data.keys().size() < 20;
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    // ============================================
    // PROFILE METRICS Collection (aggregated counts)
    // 🔒 SECURED: Owner-only write (was: any authenticated user)
    // ============================================
    match /profile_metrics/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // ============================================
    // COUNTERS Collection (Numeric ID assignment)
    // 🔒 SECURED: Only Cloud Functions should manage counters
    // Client reads allowed for ID lookup
    // ============================================
    match /counters/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Cloud Functions only — prevents race conditions
    }

    // ============================================
    // SEARCH ANALYTICS Collections
    // 🔒 SECURED: Size-limited creates, admin-only read
    // ============================================
    match /searchAnalytics/{eventId} {
      allow create: if isReasonableSize() && request.resource.data.keys().size() < 15;
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    match /searchClicks/{eventId} {
      allow create: if isReasonableSize() && request.resource.data.keys().size() < 15;
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    match /searchAggregates/{docId} {
      allow read: if true; // aggregates are public stats
      allow write: if false; // Cloud Functions only — prevent manipulation
    }

    // ============================================
    // CAR ANALYTICS Collections
    // 🔒 SECURED: Size-limited creates
    // ============================================
    match /car_views/{eventId} {
      allow create: if isReasonableSize() && request.resource.data.keys().size() < 15;
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    match /car_inquiries/{eventId} {
      allow create: if isAuthenticated() && request.resource.data.keys().size() < 15;
      allow read: if isAuthenticated() && isAdmin();
      allow update, delete: if false;
    }

    // ============================================
    // PROFILES Collection (profile-stats, profile-service)
    // 🔒 SECURED: Owner-only write (was: any authenticated user)
    // ============================================
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == profileId;
      allow update: if isAuthenticated() && request.auth.uid == profileId;
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ============================================
    // COMPANIES Collection (dealer/company profiles)
    // 🔒 SECURED: Owner-only update (was: any authenticated user)
    // ============================================
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && isAdmin();
    }

    // ============================================
    // DEALERS Collection
    // 🔒 SECURED: Owner-only write (was: any authenticated user)
    // ============================================
