rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPERS & FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Rate limiting: max 100 reads per minute
    function rateLimitExceeded() {
      return request.time < resource.data.lastRead.toMillis() + 600; // 10 seconds min between reads
    }
    
    // ============================================
    // USERS Collection
    // ============================================
    match /users/{userId} {
      // Only user can read/write their own profile
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'createdAt'])
        && request.resource.data.size() < 50; // Max 50 fields
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) // Users can't change their role (but existing role is preserved on merge)
        && request.resource.data.size() < 50;
      allow delete: if isAdmin();
      
      // For nested user documents
      match /{document=**} {
        allow read: if isAuthenticated() && (
          // User can read their own data
          isOwner(userId) ||
          // Admins can read all
          isAdmin() ||
          // Public profile fields (limited access)
          document.includes('publicProfile')
        );
        allow write: if isOwner(userId) && !isAdmin();
      }
    }
    
    // ============================================
    // APP SETTINGS Collection
    // ============================================
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // CARS Collection (Listings) - Legacy
    // ============================================
    match /cars/{carId} {
      // Anyone can read active/published cars
      allow read: if true;
      
      // Sellers can create cars
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.sellerId;
      
      // Only seller can update their own listing
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      
      // Only seller or admin can delete
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // VEHICLE COLLECTIONS (All Vehicle Types)
    // ============================================
    match /passenger_cars/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /suvs/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /vans/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /motorcycles/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /trucks/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /buses/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /construction_machines/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /agricultural_machines/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /trailers/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /campers/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /forklifts/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /boats/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    match /listings/{carId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // WORKFLOW Collections (Drafts, Progress, Images)
    // ============================================
    match /workflow_drafts/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow write: if isAuthenticated();
    }
    
    match /workflow_progress/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow write: if isAuthenticated();
    }
    
    match /workflow_images/{docId} {
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      allow write: if isAuthenticated();
    }
    
    // ============================================
    // DEALERSHIPS Collection
    // ============================================
    match /dealerships/{dealershipId} {
      // Anyone can read dealerships (public showcase)
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // POSTS Collection (Social Feed)
    // ============================================
    match /posts/{postId} {
      // Anyone can read published posts
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (
          resource.data.userId == request.auth.uid || isAdmin()
        );
      }
    }
    
    // ============================================
    // STORIES Collection
    // ============================================
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // REVIEWS Collection
    // ============================================
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if resource.data.published == true;
      
      // Authenticated users can create reviews
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.reviewerId
        && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.keys().hasAll(['reviewerId', 'rating', 'createdAt']);
      
      // Only reviewer or admin can update
      allow update: if isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid || isAdmin()
      );
      
      // Only reviewer or admin can delete
      allow delete: if isAuthenticated() && (
        resource.data.reviewerId == request.auth.uid || isAdmin()
      );
    }
    
    // ============================================
    // MESSAGES Collection (Chat)
    // ============================================
    match /messages/{messageId} {
      // Only sender and receiver can read
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      
      // Only sender can create
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.keys().hasAll(['senderId', 'receiverId', 'text', 'createdAt']);
      
      // Only sender can update
      allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;
      
      // Only sender or receiver can delete
      allow delete: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }
    
    // ============================================
    // FAVORITES Collection
    // ============================================
    match /favorites/{document=**} {
      // Users can read only their own favorites
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         request.query.userId == request.auth.uid);
      
      // Users can write only their own favorites
      allow write: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
    }
    
    // ============================================
    // ANALYTICS Collection (Read-only aggregates)
    // ============================================
    match /analytics/{document=**} {
      // Anyone can read analytics (public stats)
      allow read: if true;
      
      // Only backend/admin can write
      allow write: if false; // Use Cloud Functions for writes
    }
    
    // ============================================
    // ADMIN Collection
    // ============================================
    match /admins/{userId} {
      // Only admins can read/write
      allow read, write: if isAuthenticated() && isAdmin();
    }
    
    // ============================================
    // TRANSACTIONS Collection
    // ============================================
    match /transactions/{transactionId} {
      // Users can only read their own transactions
      allow read: if isAuthenticated() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid
      );
      
      // Only backend/Cloud Functions can write
      allow write: if false;
    }
    
    // ============================================
    // DEFAULT DENY ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
