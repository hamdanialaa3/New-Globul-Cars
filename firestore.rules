rules_version = '2';

/**
 * Firestore Security Rules for Globul Cars Bulgarian Marketplace
 * PRODUCTION VERSION with RBAC using Custom Claims
 * Location: Bulgaria | Languages: BG, EN | Currency: EUR
 * 
 * Key improvements:
 * - Uses Custom Claims for role checking (no extra reads)
 * - Implements proper RBAC (buyer, seller, admin)
 * - Optimized for performance and cost
 * - Production-ready security
 */

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    /**
     * Check if user is authenticated
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * Check if user is a buyer (default role)
     * Uses Custom Claims - no database read required
     */
    function isBuyer() {
      return isSignedIn() && request.auth.token.role == 'buyer';
    }
    
    /**
     * Check if user is a seller
     * Uses Custom Claims - no database read required
     */
    function isSeller() {
      return isSignedIn() && request.auth.token.seller == true;
    }
    
    /**
     * Check if user is an admin
     * Uses Custom Claims - no database read required
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    /**
     * Check if user is the owner of a resource
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Check if user is owner OR admin
     */
    function isOwnerOrAdmin(userId) {
      return isOwner(userId) || isAdmin();
    }
    
    // ==================== USERS COLLECTION ====================
    
    match /users/{userId} {
      // Read: Any authenticated user can read any profile (for Users Directory)
      allow get: if isSignedIn();
      
      // List: Authenticated users can browse users directory
      allow list: if isSignedIn();
      
      // Create: User can create their own profile on signup
      allow create: if isOwner(userId) && 
                       request.resource.data.uid == userId &&
                       request.resource.data.email == request.auth.token.email;
      
      // Update: User can update their own profile, admins can update any
      // 🎯 FIXED: Allow profileType changes (with validation)
      allow update: if isOwnerOrAdmin(userId) && (
        // If profileType is being changed, validate it's one of the allowed values
        !('profileType' in request.resource.data) ||
        request.resource.data.profileType in ['private', 'dealer', 'company']
      );
      
      // Delete: Only admins can delete users
      allow delete: if isAdmin();
      
      // FCM Tokens subcollection
      match /fcmTokens/{token} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ==================== CARS COLLECTION ====================
    
    match /cars/{carId} {
      // Read: Everyone can read active cars
      allow get: if resource.data.status == 'active' || 
                    isOwner(resource.data.sellerId) ||
                    isAdmin();
      
      // List: Everyone can list active cars (for search/browse)
      allow list: if true;
      
      // Create: Only sellers and admins can create car listings
      allow create: if (isSeller() || isAdmin()) &&
                       request.resource.data.sellerId == request.auth.uid &&
                       request.resource.data.sellerEmail == request.auth.token.email &&
                       request.resource.data.make is string &&
                       request.resource.data.model is string &&
                       request.resource.data.year is number &&
                       request.resource.data.price is number &&
                       request.resource.data.price > 0 &&
                       request.resource.data.currency == 'EUR';
      
      // Update: Owner or admin can update
      allow update: if isOwner(resource.data.sellerId) || isAdmin();
      
      // Delete: Owner or admin can delete
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }
    
    // ==================== SELLERS COLLECTION ====================
    // Stores aggregated seller metrics and stats
    
    match /sellers/{sellerId} {
      // Read: Seller can read their own stats, everyone can read for public profile
      allow get: if true; // Public stats for transparency
      allow list: if isSignedIn();
      
      // Write: Only via Cloud Functions
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // ==================== REVIEWS COLLECTION ====================
    
    match /reviews/{reviewId} {
      // Read: Everyone can read reviews
      allow read: if true;
      
      // Create: Any authenticated user can create a review
      allow create: if isSignedIn() &&
                       request.resource.data.reviewerId == request.auth.uid &&
                       request.resource.data.rating >= 1 &&
                       request.resource.data.rating <= 5;
      
      // Update: Owner can update their review, admin can update any
      allow update: if isOwner(resource.data.reviewerId) || isAdmin();
      
      // Delete: Owner can delete their review, admin can delete any
      allow delete: if isOwner(resource.data.reviewerId) || isAdmin();
    }
    
    // ==================== CONVERSATIONS COLLECTION ====================
    // P2P messaging between users
    
    match /conversations/{conversationId} {
      // Helper to check if user is a member of the conversation
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.members;
      }
      
      // Read: Only members can read conversation metadata
      allow read: if isMember();
      
      // Create: Any two users can create a conversation
      allow create: if isSignedIn() && 
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.members.size() == 2;
      
      // Update: Members can update conversation metadata (lastMessage, etc.)
      allow update: if isMember();
      
      // Delete: Admin only
      allow delete: if isAdmin();
      
      // Messages subcollection
    match /messages/{messageId} {
        // Read: Members of parent conversation can read messages
        allow read: if isMember();
        
        // Create: Members can send messages
        allow create: if isMember() && 
                       request.resource.data.senderId == request.auth.uid;
      
        // Update: Sender can update their own message (e.g., mark as edited)
        allow update: if isOwner(resource.data.senderId);
        
        // Delete: Admin only
        allow delete: if isAdmin();
      }
    }
    
    // ==================== FAVORITES COLLECTION ====================
    
    match /favorites/{userId} {
      // Favorites stored as user document with carIds array
      allow read, write: if isOwnerOrAdmin(userId);
    }
    
    // ==================== FOLLOWS COLLECTION ====================
    // User follow/following relationships
    
    match /follows/{followId} {
      // Read: Anyone can read follow relationships (for follower counts)
      allow read: if isSignedIn();
      
      // Create: User can follow others
      allow create: if isSignedIn() && 
                       request.resource.data.followerId == request.auth.uid;
      
      // Delete: User can unfollow (delete their own follow docs)
      allow delete: if isSignedIn() && 
                       resource.data.followerId == request.auth.uid;
      
      // Admin full access
      allow read, write: if isAdmin();
    }
    
    // ==================== ANALYTICS EVENTS COLLECTION ====================
    // For tracking profile views, car views, etc.
    
    match /analytics_events/{eventId} {
      // Create: Anyone can create events (for tracking)
      allow create: if true;
      
      // Read: User can read their own events (targetUserId)
      allow read: if isSignedIn() && 
                     resource.data.targetUserId == request.auth.uid;
      
      // Admin can read/write all
      allow read, write: if isAdmin();
    }
    
    // ==================== PROFILE METRICS COLLECTION ====================
    // Aggregated profile analytics
    
    match /profile_metrics/{userId} {
      // Read: Owner can read their own metrics
      allow read: if isOwnerOrAdmin(userId);
      
      // Write: Anyone can write (for system updates via functions)
      allow write: if true;
      
      // Admin full access
      allow read, write: if isAdmin();
    }
    
    // ==================== NOTIFICATIONS COLLECTION ====================
    
    match /notifications/{userId} {
      // Read: Owner can read their notifications
      allow read: if isOwnerOrAdmin(userId);
      
      // Write: Only via Cloud Functions
      allow write: if false;
      
      // Admin full access
      allow read, write: if isAdmin();
    }
    
    // ==================== ADMIN LOGS COLLECTION ====================
    
    match /admin_logs/{logId} {
      // Read/Write: Admin only
      allow read, write: if isAdmin();
    }

    // ==================== STATS COLLECTION ====================
    // Public statistics and counters
    
    match /stats/{document=**} {
      // Read: Public
      allow read: if true;
      
      // Write: Only via Cloud Functions
      allow write: if false;
    }
    
    // ==================== SAVED SEARCHES COLLECTION ====================
    
    match /savedSearches/{userId} {
      allow read, write: if isOwnerOrAdmin(userId);
    }
    
    // ==================== AD CAMPAIGNS COLLECTIONS ====================
    
    // Campaigns Collection
    match /campaigns/{campaignId} {
      // Read: Any authenticated user can read campaigns (for display)
      allow get: if isSignedIn();
      
      // List: Owner can list their own campaigns
      allow list: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
      
      // Create: Authenticated users can create campaigns
      // Validation: budget >= 10 EUR, owner must be creator
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.budget >= 10 &&
                       request.resource.data.dailyBudget > 0 &&
                       request.resource.data.duration >= 1 &&
                       request.resource.data.status in ['draft', 'active', 'paused'];
      
      // Update: Owner can update their own campaigns (status, budget)
      // Cannot change userId or decrease spent budget
      allow update: if isOwnerOrAdmin(request.resource.data.userId) &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.spent >= resource.data.spent;
      
      // Delete: Owner or admin can delete
      allow delete: if isOwnerOrAdmin(resource.data.userId);
    }
    
    // Impressions Collection (subcollection under campaigns)
    match /campaigns/{campaignId}/impressions/{impressionId} {
      // Read: Campaign owner can read impressions
      allow read: if isSignedIn() && 
                     get(/databases/$(database)/documents/campaigns/$(campaignId)).data.userId == request.auth.uid;
      
      // Write: Only via Cloud Functions (system writes)
      allow write: if false;
    }
    
    // Daily Spending Collection (tracking daily budget usage)
    match /daily_spending/{spendingId} {
      // Read: Campaign owner can read their spending
      allow read: if isSignedIn();
      
      // Write: Only via Cloud Functions (system writes)
      allow write: if false;
    }
    
    // ==================== SOCIAL PLATFORM COLLECTIONS ====================
    
    // POSTS COLLECTION
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       request.resource.data.authorId == request.auth.uid;
      allow update: if isOwnerOrAdmin(resource.data.authorId);
      allow delete: if isOwnerOrAdmin(resource.data.authorId);
    }
    
    // MESSAGES COLLECTION
    match /messages/{messageId} {
      allow read: if isSignedIn() && 
                     (resource.data.senderId == request.auth.uid || 
                      resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && 
                       request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn() && 
                       (resource.data.senderId == request.auth.uid || 
                        resource.data.recipientId == request.auth.uid);
      allow delete: if isOwner(resource.data.senderId) || isAdmin();
    }
    
    // CHAT ROOMS COLLECTION
    match /chatRooms/{roomId} {
      allow read: if isSignedIn() && 
                     request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && 
                       request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && 
                       request.auth.uid in resource.data.participants;
      allow delete: if false;
    }
    
    // STORIES COLLECTION
    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.expiresAt > request.time;
      allow update: if isOwner(resource.data.authorId);
      allow delete: if isOwnerOrAdmin(resource.data.authorId) ||
                       resource.data.expiresAt < request.time;
      
      match /views/{viewId} {
        allow read: if isOwner(get(/databases/$(database)/documents/stories/$(storyId)).data.authorId);
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }
    
    // EVENTS COLLECTION
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       request.resource.data.organizerId == request.auth.uid;
      allow update: if isOwnerOrAdmin(resource.data.organizerId);
      allow delete: if isOwnerOrAdmin(resource.data.organizerId);
    }
    
    // EVENT RSVPs COLLECTION
    match /eventRSVPs/{rsvpId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // CONSULTATIONS COLLECTION
    match /consultations/{consultationId} {
      allow read: if isSignedIn() && 
                     (resource.data.clientId == request.auth.uid || 
                      resource.data.expertId == request.auth.uid ||
                      resource.data.visibility == 'public');
      allow create: if isSignedIn() && 
                       request.resource.data.clientId == request.auth.uid;
      allow update: if isSignedIn() && 
                       (resource.data.clientId == request.auth.uid || 
                        resource.data.expertId == request.auth.uid);
      allow delete: if isOwner(resource.data.clientId) || isAdmin();
    }
    
    // FOLLOWS COLLECTION
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                       request.resource.data.followerId == request.auth.uid;
      allow delete: if isOwner(resource.data.followerId) || isAdmin();
    }
    
    // NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // USER BADGES COLLECTION
    match /userBadges/{badgeId} {
      allow read: if isSignedIn();
      allow create: if false; // Only created by Cloud Functions
      allow update, delete: if isAdmin();
    }
    
    // ANALYTICS COLLECTION
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if false; // Only written by Cloud Functions
    }
    
    // REPORTS & MODERATION
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && 
                       request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    
    // ==================== DEFAULT DENY ====================
    // Deny all other operations by default
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

