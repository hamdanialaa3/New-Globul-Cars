# Copy this file to: extensions/algolia-firestore-search.params.local
# Then replace the CHANGE_ME values and remove comment lines if needed.

DATABASE_ID=(default)
LOCATION=europe-west3

# Firestore collection and fields
COLLECTION_PATH=cars
INDEXABLE_FIELDS=title,make,model,year,price,mileage,fuelType,transmission,city,region,keywords,description,sellerType
FORCE_DATA_SYNC=false
FULL_INDEX=true

# Algolia settings
ALGOLIA_INDEX_NAME=cars_bg
ALGOLIA_APP_ID=CHANGE_ME_APP_ID
ALGOLIA_API_KEY=CHANGE_ME_ADMIN_API_KEY

# Optional
ALTERNATIVE_OBJECT_ID=
TRANSFORM_FUNCTION_NAME=
