{
  "functions": {
    "codebase": "default",
    "source": "functions",
    "runtime": "nodejs20",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ],
    "predeploy": [
      "npm run build -- --noEmit false --skipLibCheck --outDir lib src/subscriptions/*.ts src/subscriptions/**/*.ts"
    ]
  },
  "hosting": {
    "public": "bulgarian-car-marketplace/build",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
