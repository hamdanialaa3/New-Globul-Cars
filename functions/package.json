{
  "name": "functions",
  "description": "Cloud Functions for Bulgarian Car Marketplace",
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "echo 'Linting functions...'",
    "build": "tsc",
    "test": "node -r ts-node/register test/social-tokens.test.ts"
  },
  "engines": {
    "node": "18"
  },
  "main": "index.js",
  "dependencies": {
    "@google-cloud/recaptcha-enterprise": "^6.3.0",
    "@google-cloud/secret-manager": "^6.1.0",
    "@google-cloud/translate": "^9.2.0",
    "@google-cloud/vision": "^5.3.3",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "axios": "^1.4.0",
    "firebase-admin": "^11.8.0",
    "firebase-functions": "^4.3.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^24.7.1",
    "firebase-functions-test": "^3.1.0",
    "mocha": "^10.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "private": true
}
