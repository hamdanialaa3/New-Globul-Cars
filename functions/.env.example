# Zero-Cost AI Implementation - Environment Variables Template
# نسخ هذا الملف إلى .env (في مجلد functions/) وملء القيم الفعلية

# ==================== Firebase Project ====================
FIREBASE_PROJECT_ID=fire-new-globul
FIREBASE_PROJECT_NUMBER=973379297533

# ==================== Email Configuration ====================
# استخدام Gmail مع App Password (أو SendGrid)
EMAIL_SMTP_USER=globul.net.m@gmail.com
EMAIL_SMTP_PASS=<your_gmail_app_password_here>
# بدلاً من Gmail، يمكنك استخدام SendGrid:
# SENDGRID_API_KEY=<your_sendgrid_api_key>

# عنوان البريد المستلم للتنبيهات الإدارية
ADMIN_EMAIL=globul.net.m@gmail.com

# ==================== Gemini AI Configuration ====================
# مفتاح Gemini API المجاني (1500 طلب/يوم)
GEMINI_API_KEY=<your_gemini_api_key_here>
# النموذج المفضل
GEMINI_MODEL=gemini-1.5-flash

# ==================== AI Assistant Display Names ====================
# اسم المساعد الذكي بالبلغارية والإنجليزية
AI_DISPLAY_NAME_BG=Clover Alina
AI_DISPLAY_NAME_EN=Clover Alina

# ==================== Performance & Monitoring ====================
# تفعيل Firebase Performance في الإنتاج
ENABLE_PERFORMANCE_MONITORING=true

# ==================== Development Settings ====================
# استخدام المحاكيات المحلية (true في التطوير، false في الإنتاج)
USE_EMULATORS=false

# ملاحظات أمنية مهمة:
# 1. لا تضع هذا الملف في Git أبداً (.env مدرج في .gitignore)
# 2. دوّر كلمات المرور بانتظام (شهرياً على الأقل)
# 3. استخدم Gmail App Password وليس كلمة المرور الأساسية
# 4. احفظ نسخة احتياطية آمنة من هذا الملف خارج المستودع

# خطوات إنشاء Gmail App Password:
# 1. افتح https://myaccount.google.com/security
# 2. فعّل Two-Factor Authentication إن لم يكن مفعلاً
# 3. ابحث عن "App passwords"
# 4. أنشئ كلمة مرور جديدة باسم "New Globul Cars Functions"
# 5. انسخها والصقها في EMAIL_SMTP_PASS أعلاه (بدون مسافات)

# للنشر على Firebase Functions، استخدم:
# firebase functions:config:set email.smtp_user="..." email.smtp_pass="..." alerts.admin_email="..." gemini.api_key="..." gemini.model="gemini-1.5-flash"
