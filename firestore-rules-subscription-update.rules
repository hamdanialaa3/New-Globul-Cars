/**
 * Firestore Security Rules - Subscription System
 * 
 * File: firestore-rules-subscription-update.rules
 * Purpose: Security rules for new subscription features (Micro-Transactions + Churn Prevention)
 * Created: January 7, 2026
 * 
 * INSTRUCTIONS:
 * 1. Add these rules to your existing firestore.rules file
 * 2. Deploy with: firebase deploy --only firestore:rules
 * 3. Test in Firebase Console → Firestore → Rules Playground
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===========================================
    // HELPER FUNCTIONS
    // ===========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function hasValidSubscription(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      return userData.subscription != null && 
             userData.subscription.status == 'active';
    }
    
    // ===========================================
    // MICRO-TRANSACTIONS (NEW - Jan 7, 2026)
    // ===========================================
    
    // Rule: Users can read their own promotions
    // Rule: Only Cloud Functions can write promotions (prevents fraud)
    match /listings/{listingId}/promotions/{promotionId} {
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Only Cloud Functions can create/update promotions after payment
      allow write: if false; // Frontend never writes directly
    }
    
    // Rule: Users can read active promotions for any listing (for display)
    match /listings/{listingId}/promotions/{promotionId} {
      allow get: if isAuthenticated() && 
                    resource.data.isActive == true;
    }
    
    // Rule: Track promotion purchase history
    match /users/{userId}/promotions/{promotionId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions write
    }
    
    // ===========================================
    // CHURN PREVENTION (NEW - Jan 7, 2026)
    // ===========================================
    
    // Rule: Users can read their own grace period status
    // Rule: Only Cloud Functions can modify grace period
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // Allow updating only specific fields (not grace period)
      allow update: if isOwner(userId) && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                         'subscription.gracePeriod',
                         'subscription.retentionOffers'
                       ]);
    }
    
    // Rule: Grace period reminders (Cloud Functions only)
    match /users/{userId}/subscription_events/{eventId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions
    }
    
    // ===========================================
    // SUBSCRIPTION STATUS (EXISTING - Enhanced)
    // ===========================================
    
    // Rule: Users can read their subscription but not modify directly
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Prevent users from changing their own plan tier or status
      allow update: if isOwner(userId) && 
                       request.resource.data.subscription.tier == resource.data.subscription.tier &&
                       request.resource.data.subscription.status == resource.data.subscription.status;
    }
    
    // ===========================================
    // LISTINGS WITH PLAN ENFORCEMENT
    // ===========================================
    
    // Rule: Enforce listing limits based on plan tier
    match /{collectionGroup}/{listingId} {
      // collectionGroup can be: passenger_cars, suvs, vans, motorcycles, trucks, buses
      
      allow read: if true; // Public listings
      
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       // Verify listing limit (Cloud Function will double-check)
                       canCreateListing(request.auth.uid);
      
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      allow delete: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
    }
    
    // Helper function: Check if user can create listing
    function canCreateListing(userId) {
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      let currentCount = userData.stats.activeListings;
      let tier = userData.subscription.tier;
      
      // Plan limits (must match subscription-plans.ts)
      let maxListings = tier == 'free' ? 3 :
                        tier == 'dealer' ? 30 :  // ✅ FIXED: was 10
                        tier == 'company' ? 999999 :  // Unlimited
                        0;
      
      return currentCount < maxListings;
    }
    
    // ===========================================
    // STRIPE WEBHOOKS (Security)
    // ===========================================
    
    // Rule: Only Stripe webhook Cloud Function can write payment events
    match /payment_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions via webhook
    }
    
    // ===========================================
    // ANALYTICS (Read-only for users)
    // ===========================================
    
    // Rule: Users can view their own analytics
    match /users/{userId}/analytics/{docId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions track analytics
    }
    
    // Rule: Company plan users can access advanced analytics
    match /users/{userId}/advanced_analytics/{docId} {
      allow read: if isOwner(userId) && 
                     get(/databases/$(database)/documents/users/$(userId)).data.subscription.tier == 'company';
      allow write: if false;
    }
    
    // ===========================================
    // BILLING HISTORY (Immutable)
    // ===========================================
    
    // Rule: Users can read billing history but never modify
    match /users/{userId}/billing_history/{invoiceId} {
      allow read: if isOwner(userId);
      allow create: if false; // Only Stripe webhook creates
      allow update, delete: if false; // Immutable
    }
    
    // ===========================================
    // ADMIN OVERRIDES
    // ===========================================
    
    // Rule: Admins can manage subscriptions manually
    match /admin_actions/{actionId} {
      allow read, write: if isAdmin();
    }
    
    // Rule: Admins can override grace periods
    match /users/{userId} {
      allow update: if isAdmin() && 
                       request.resource.data.subscription.adminOverride == true;
    }
  }
}

/**
 * TESTING CHECKLIST
 * 
 * Before deploying, test these scenarios in Rules Playground:
 * 
 * ✅ User can read their own promotions
 * ❌ User cannot write promotions directly
 * ✅ User can read their grace period status
 * ❌ User cannot modify their own grace period
 * ✅ Free user blocked at 4th listing
 * ✅ Dealer user blocked at 31st listing (NOT 11th!)
 * ✅ Company user can create unlimited listings
 * ❌ User cannot change their own plan tier
 * ✅ Cloud Function can write payment events
 * ❌ Frontend cannot write payment events
 * 
 * DEPLOYMENT:
 * 1. Merge into firestore.rules
 * 2. Run: firebase deploy --only firestore:rules
 * 3. Monitor logs: firebase functions:log --only firestore
 * 4. Test in production with test users (free, dealer, company)
 */
