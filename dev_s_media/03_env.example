# 🌐 Social Media Automation - Environment Config
# Rename this file to .env.production (DO NOT COMMIT IT)

# --- 🟢 General Setup ---
NODE_ENV=production
# The main Postgres DB for Metadata & Logs
DATABASE_URL=postgresql://user:password@localhost:5432/koli_media_db
# Redis for BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- 🔵 Facebook & Instagram (Meta Graph API) ---
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=
META_APP_SECRET=
# Generate Long-Lived Token via Graph Explorer
# Permission required: pages_manage_posts, pages_read_engagement, instagram_basic, instagram_content_publish
PAGE_ACCESS_TOKEN=
# The ID of the Facebook Page you want to post to
FB_PAGE_ID=
# The ID of the Instagram Business Account (linked to the FB Page)
IG_USER_ID=

# --- 🧠 Local AI (LLM) ---
# URL where your Python wrapper is running
LLM_API_URL=http://localhost:5000/generate
# Optional: API Key if you secure the local wrapper
LLM_API_KEY=local-secret-key

# --- 🛡️ Security & Monitoring ---
# Webhook secret to verify calls from Core Backend
WEBHOOK_SECRET=change_me_to_something_secure_random
# Sentry DSN for Error Tracking
SENTRY_DSN=
# Admin Email for DLQ Alerts
ADMIN_EMAIL=admin@koli.one
