{
  "n8n_globul_cars_integration": {
    "project_info": {
      "name": "Globul Cars - Bulgarian Car Marketplace",
      "version": "1.0.0",
      "description": "Complete n8n integration workflows for Bulgarian car marketplace",
      "base_url": "http://localhost:3000",
      "n8n_url": "http://localhost:5678",
      "firebase_project": "fire-new-globul"
    },

    "workflows": {
      "1_car_listing_automation": {
        "name": "Car Listing Complete Automation",
        "description": "End-to-end automation for car selling process",
        "trigger": "Webhook",
        "webhook_url": "/webhook/sell-started",
        "steps": [
          {
            "id": 1,
            "name": "User Journey Logging",
            "action": "Log user start selling process",
            "data": ["userId", "userProfile", "timestamp"]
          },
          {
            "id": 2,
            "name": "Vehicle Type Analysis",
            "action": "Analyze selected vehicle type",
            "webhook": "/webhook/vehicle-type-selected",
            "logic": "Commercial vehicles -> Auto-detect business account"
          },
          {
            "id": 3,
            "name": "Seller Type Detection",
            "action": "Auto-detect or confirm seller type",
            "webhook": "/webhook/seller-type-detected",
            "business_rules": {
              "if_business_account": "Auto-select dealer type",
              "if_multiple_cars": "Suggest dealer upgrade",
              "if_first_time": "Show helpful tips"
            }
          },
          {
            "id": 4,
            "name": "Vehicle Data Validation",
            "action": "Validate and enrich vehicle data",
            "webhook": "/webhook/vehicle-data-entered",
            "validations": [
              "VIN verification",
              "Make/Model consistency",
              "Year range check",
              "Mileage reasonability"
            ]
          },
          {
            "id": 5,
            "name": "Image Processing Pipeline",
            "action": "Process uploaded images",
            "webhook": "/webhook/images-uploaded",
            "processing": [
              "Auto-resize to optimal sizes",
              "Add watermark with Globul.net",
              "Generate thumbnails",
              "Extract image metadata",
              "Check for inappropriate content"
            ]
          },
          {
            "id": 6,
            "name": "Price Analysis & Suggestions",
            "action": "Analyze pricing and suggest optimizations",
            "webhook": "/webhook/price-set",
            "analysis": [
              "Market comparison",
              "Price history analysis",
              "Similar cars pricing",
              "Bulgarian market trends",
              "Suggest optimal price range"
            ]
          },
          {
            "id": 7,
            "name": "Multi-Platform Publishing",
            "action": "Publish car to multiple platforms",
            "webhook": "/webhook/car-published",
            "platforms": [
              "Globul.net (primary)",
              "Facebook Marketplace",
              "Bulgarian car portals",
              "Social media sharing",
              "WhatsApp Business catalog"
            ]
          },
          {
            "id": 8,
            "name": "Success Notifications",
            "action": "Send confirmation and next steps",
            "notifications": [
              "Email confirmation (BG/EN)",
              "SMS notification",
              "Push notification",
              "Dashboard update"
            ]
          }
        ]
      },

      "2_user_lifecycle_management": {
        "name": "User Lifecycle & Engagement",
        "description": "Comprehensive user onboarding and engagement system",
        "triggers": [
          {
            "event": "user_registered",
            "webhook": "/webhook/user-registered"
          },
          {
            "event": "account_verified",
            "webhook": "/webhook/account-verified"
          },
          {
            "event": "profile_completed",
            "webhook": "/webhook/profile-completed"
          }
        ],
        "workflows": [
          {
            "name": "New User Onboarding",
            "steps": [
              "Send welcome email (Bulgarian/English)",
              "Create initial profile structure",
              "Track registration source",
              "Schedule follow-up reminders",
              "Add to appropriate user segments"
            ]
          },
          {
            "name": "Account Verification Flow",
            "steps": [
              "Send verification email",
              "Track verification rate",
              "Send reminders to unverified users",
              "Flag suspicious registrations",
              "Update user status in Firebase"
            ]
          },
          {
            "name": "Business Account Activation",
            "steps": [
              "Verify business documents",
              "Enable advanced features",
              "Send business user guide",
              "Schedule onboarding call",
              "Add to business user segment"
            ]
          }
        ]
      },

      "3_communication_hub": {
        "name": "Real-time Communication Automation",
        "description": "Automated messaging, notifications, and communication workflows",
        "triggers": [
          {
            "event": "message_sent",
            "webhook": "/webhook/message-sent"
          },
          {
            "event": "offer_submitted",
            "webhook": "/webhook/offer-submitted"
          },
          {
            "event": "car_favorited",
            "webhook": "/webhook/car-favorited"
          }
        ],
        "automations": [
          {
            "name": "Smart Notifications",
            "logic": [
              "Determine notification preference (email/SMS/push)",
              "Check user's online status",
              "Apply do-not-disturb rules",
              "Send in user's preferred language",
              "Track delivery and open rates"
            ]
          },
          {
            "name": "Auto-Translation Service",
            "workflow": [
              "Detect message language",
              "Translate if needed (BG <-> EN)",
              "Preserve original message",
              "Flag for manual review if complex"
            ]
          },
          {
            "name": "Response Templates & AI",
            "features": [
              "Suggest quick responses",
              "Generate professional replies",
              "Auto-answer common questions",
              "Schedule follow-up messages"
            ]
          },
          {
            "name": "Negotiation Assistant",
            "workflow": [
              "Track offer history",
              "Calculate counter-offer suggestions",
              "Identify serious buyers",
              "Suggest optimal timing for responses"
            ]
          }
        ]
      },

      "4_analytics_and_intelligence": {
        "name": "Business Intelligence & Analytics",
        "description": "Automated data analysis and business insights",
        "data_sources": [
          "Firebase Analytics",
          "User interactions",
          "Car listings performance",
          "Search patterns",
          "Geographic data",
          "Market trends"
        ],
        "reports": [
          {
            "name": "Daily Performance Report",
            "schedule": "Every day at 8:00 AM",
            "content": [
              "New registrations",
              "Cars listed/sold",
              "Top performing listings",
              "User engagement metrics",
              "Revenue analytics"
            ],
            "recipients": ["admin@globul.net", "analytics@globul.net"]
          },
          {
            "name": "Weekly Market Insights",
            "schedule": "Every Monday at 9:00 AM",
            "content": [
              "Popular car brands/models",
              "Price trends by region",
              "User behavior patterns",
              "Competitive analysis",
              "Growth opportunities"
            ]
          },
          {
            "name": "Monthly Business Review",
            "schedule": "First day of each month",
            "content": [
              "Complete performance overview",
              "ROI analysis",
              "User retention metrics",
              "Market share analysis",
              "Strategic recommendations"
            ]
          }
        ],
        "alerts": [
          {
            "name": "System Performance Alert",
            "condition": "Response time > 3 seconds",
            "action": "Send immediate alert to DevOps team"
          },
          {
            "name": "Unusual Activity Alert", 
            "condition": "Suspicious user behavior detected",
            "action": "Flag for manual review and notify security team"
          },
          {
            "name": "Revenue Milestone Alert",
            "condition": "Daily revenue exceeds target by 20%",
            "action": "Celebrate with team and analyze success factors"
          }
        ]
      },

      "5_advanced_automations": {
        "name": "Advanced Business Process Automation",
        "description": "Complex business logic and advanced automations",
        "processes": [
          {
            "name": "Dynamic Pricing Engine",
            "workflow": [
              "Collect market data from competitors",
              "Analyze similar car prices in Bulgaria",
              "Consider seasonal trends",
              "Factor in car condition and mileage",
              "Generate pricing recommendations",
              "Update suggested prices automatically"
            ],
            "schedule": "Every 6 hours"
          },
          {
            "name": "Inventory Management",
            "workflow": [
              "Track car listing lifecycle",
              "Identify stale listings",
              "Suggest pricing adjustments",
              "Auto-promote underperforming listings",
              "Schedule follow-ups with sellers"
            ]
          },
          {
            "name": "Quality Assurance System",
            "workflow": [
              "Review all new listings",
              "Check for policy violations",
              "Verify image quality",
              "Validate contact information",
              "Flag suspicious listings",
              "Auto-approve verified sellers"
            ]
          },
          {
            "name": "Customer Success Engine",
            "workflow": [
              "Identify at-risk users",
              "Predict churn probability",
              "Trigger retention campaigns",
              "Personalize user experience",
              "Recommend relevant cars",
              "Schedule check-in calls"
            ]
          }
        ]
      }
    },

    "integration_points": {
      "frontend_hooks": [
        {
          "location": "/sell/auto",
          "hook": "N8nIntegrationService.onSellStarted()",
          "data": ["userId", "userProfile"]
        },
        {
          "location": "/sell/inserat/:type/verkaeufertyp", 
          "hook": "N8nIntegrationService.onSellerTypeDetected()",
          "data": ["userId", "sellerType", "isAutoDetected"]
        },
        {
          "location": "/sell/inserat/:type/fahrzeugdaten",
          "hook": "N8nIntegrationService.onVehicleDataEntered()",
          "data": ["userId", "vehicleData"]
        },
        {
          "location": "/sell/inserat/:type/details/bilder",
          "hook": "N8nIntegrationService.onImagesUploaded()",
          "data": ["userId", "carId", "imageCount"]
        },
        {
          "location": "/sell/inserat/:type/details/preis",
          "hook": "N8nIntegrationService.onPriceSet()",
          "data": ["userId", "carId", "price", "currency"]
        }
      ],
      "firebase_triggers": [
        {
          "collection": "users",
          "event": "create",
          "webhook": "/webhook/user-registered"
        },
        {
          "collection": "cars",
          "event": "create", 
          "webhook": "/webhook/car-published"
        },
        {
          "collection": "messages",
          "event": "create",
          "webhook": "/webhook/message-sent"
        }
      ],
      "scheduled_tasks": [
        {
          "name": "Daily Analytics Processing",
          "schedule": "0 6 * * *",
          "webhook": "/webhook/daily-analytics"
        },
        {
          "name": "Weekly Market Analysis",
          "schedule": "0 9 * * 1",
          "webhook": "/webhook/weekly-analysis"
        },
        {
          "name": "Monthly Business Review",
          "schedule": "0 9 1 * *",
          "webhook": "/webhook/monthly-review"
        }
      ]
    },

    "environment_config": {
      "development": {
        "n8n_url": "http://localhost:5678",
        "webhook_base": "http://localhost:5678/webhook",
        "firebase_project": "studio-448742006-a3493",
        "enable_logging": true,
        "mock_external_apis": true
      },
      "production": {
        "n8n_url": "https://n8n.globul.net",
        "webhook_base": "https://n8n.globul.net/webhook", 
        "firebase_project": "fire-new-globul",
        "enable_logging": false,
        "mock_external_apis": false
      }
    },

    "monitoring_and_health": {
      "health_checks": [
        {
          "name": "N8N Connection Health",
          "endpoint": "/healthz",
          "interval": "5 minutes",
          "alert_threshold": 3
        },
        {
          "name": "Webhook Response Times",
          "metric": "response_time",
          "threshold": "5 seconds",
          "alert": "Slack notification"
        }
      ],
      "metrics": [
        "Webhook success rate",
        "Average processing time",
        "Failed automation count",
        "User engagement improvements",
        "Revenue impact from automations"
      ]
    },

    "security_and_compliance": {
      "authentication": "Firebase Auth tokens",
      "data_encryption": "HTTPS only",
      "rate_limiting": "100 requests per minute per user",
      "gdpr_compliance": [
        "Data anonymization in workflows",
        "Consent tracking",
        "Right to be forgotten automation"
      ],
      "audit_logging": [
        "All webhook calls",
        "User data access",
        "Automation executions",
        "Security events"
      ]
    },

    "deployment_steps": [
      {
        "step": 1,
        "title": "Setup N8N Instance",
        "actions": [
          "Install n8n on server",
          "Configure PostgreSQL database",
          "Setup SSL certificates",
          "Configure environment variables"
        ]
      },
      {
        "step": 2,
        "title": "Import Workflows",
        "actions": [
          "Export workflows from development",
          "Import to production n8n",
          "Test all webhook endpoints",
          "Verify database connections"
        ]
      },
      {
        "step": 3,
        "title": "Frontend Integration",
        "actions": [
          "Deploy n8n-integration.ts service",
          "Update environment variables",
          "Test all integration points",
          "Enable production monitoring"
        ]
      },
      {
        "step": 4,
        "title": "Monitoring Setup",
        "actions": [
          "Configure health checks",
          "Setup alerting system",
          "Create monitoring dashboards",
          "Test alert channels"
        ]
      }
    ],

    "next_steps": [
      "Create basic workflows in n8n interface",
      "Test webhook connectivity",
      "Implement frontend integration hooks",
      "Setup monitoring and alerting",
      "Train team on n8n workflow management",
      "Gradual rollout to production users"
    ]
  }
}