{
  "_comment": "Recommended composite indexes (not enforced). Align with firestore-profile-domain.md",
  "indexes": [
    {
      "collectionGroup": "listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "ownerProfileId", "order": "ASCENDING" },
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "publishedAt", "order": "DESCENDING" }
      ],
      "reason": "Profile dashboard recent published listings"
    },
    {
      "collectionGroup": "listings",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "make", "order": "ASCENDING" },
        { "fieldPath": "model", "order": "ASCENDING" },
        { "fieldPath": "priceEur", "order": "ASCENDING" }
      ],
      "reason": "Saved searches multi-field filtering"
    },
    {
      "collectionGroup": "posts",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "type", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ],
      "reason": "Posts feed filtering by type with recency ordering"
    },
    {
      "collectionGroup": "savedSearches",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "userId", "order": "ASCENDING" },
        { "fieldPath": "createdAt", "order": "DESCENDING" }
      ],
      "reason": "Display user saved searches sorted by creation date"
    }
  ]
}
