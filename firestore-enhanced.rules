/**
 * Enhanced Firestore Security Rules
 * Zero-Cost AI Implementation - Phase 2.4
 * 
 * Features:
 * - Rate limiting for AI operations
 * - Quota enforcement per plan tier
 * - IP blocking (via custom claims)
 * - Fraud prevention rules
 * - Data validation
 * 
 * Replaces: Paid fraud detection services (€500+/month)
 * Cost: €0 (built-in Firebase feature)
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.get('isAdmin', false) == true;
    }
    
    // Check if user is blocked (custom claim set by Cloud Functions)
    function isBlocked() {
      return isAuthenticated() && 
             request.auth.token.get('blocked', false) == true;
    }
    
    // Validate profile type
    function isValidProfileType(profileType) {
      return profileType in ['private', 'dealer', 'company'];
    }
    
    // Validate plan tier (Phase 0 Day 4)
    function isValidPlanTier(tier) {
      return tier in ['free', 'dealer', 'company'];
    }
    
    // Check if plan tier matches profile type (Phase 0 Day 4)
    function planTierMatchesProfileType(profileType, planTier) {
      return (profileType == 'private' && planTier == 'free') ||
             (profileType == 'dealer' && planTier == 'dealer') ||
             (profileType == 'company' && planTier == 'company');
    }
    
    // AI Quota limits per plan (daily)
    function getAIQuotaLimit(planTier) {
      return planTier == 'free' ? 10 :
             planTier == 'premium' ? 50 :
             planTier == 'dealer_basic' ? 100 :
             planTier == 'dealer_pro' ? 300 :
             planTier == 'dealer_enterprise' ? 1000 :
             planTier == 'company_starter' ? 200 :
             planTier == 'company_pro' ? 500 :
             planTier == 'company_enterprise' ? 2000 : 10; // Default to free tier
    }
    
    // Check AI quota (read from user's ai_usage document)
    function hasAIQuota(userId, planTier) {
      let usage = get(/databases/$(database)/documents/users/$(userId)/ai_usage/daily).data;
      let today = request.time.toMillis() / (24 * 60 * 60 * 1000); // Days since epoch
      let lastUsageDay = usage.get('lastUsageDay', 0);
      let todayCount = (today == lastUsageDay) ? usage.get('count', 0) : 0;
      return todayCount < getAIQuotaLimit(planTier);
    }
    
    // Listing limits per plan tier
    function getListingLimit(planTier) {
      return planTier == 'free' ? 3 :
             planTier == 'premium' ? 999999 : // Unlimited
             planTier == 'dealer_basic' ? 20 :
             planTier == 'dealer_pro' ? 100 :
             planTier == 'dealer_enterprise' ? 999999 :
             planTier == 'company_starter' ? 50 :
             planTier == 'company_pro' ? 200 :
             planTier == 'company_enterprise' ? 999999 : 3;
    }
    
    // Check listing quota
    function hasListingQuota(userId, planTier) {
      let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
      let activeListings = userDoc.get('activeListingsCount', 0);
      return activeListings < getListingLimit(planTier);
    }
    
    // Rate limiting: Max 100 writes per minute per user (anti-spam)
    function isRateLimited(userId) {
      let rateDoc = get(/databases/$(database)/documents/rate_limits/$(userId)).data;
      let now = request.time.toMillis();
      let windowStart = rateDoc.get('windowStart', 0);
      let requestCount = rateDoc.get('requestCount', 0);
      
      // Reset counter if window expired (1 minute = 60000ms)
      let withinWindow = (now - windowStart) < 60000;
      let currentCount = withinWindow ? requestCount : 0;
      
      return currentCount > 100;
    }
    
    // Validate car data structure
    function isValidCarData(data) {
      return data.keys().hasAll(['title', 'make', 'model', 'year', 'price', 'seller']) &&
             data.title is string && data.title.size() >= 10 && data.title.size() <= 200 &&
             data.make is string && data.make.size() >= 2 && data.make.size() <= 50 &&
             data.model is string && data.model.size() >= 1 && data.model.size() <= 100 &&
             data.year is int && data.year >= 1980 && data.year <= 2026 &&
             data.price is number && data.price >= 0 && data.price <= 10000000 &&
             data.seller is map && data.seller.id is string;
    }
    
    // Validate image limits (max 20 images per listing)
    function hasValidImageCount(images) {
      return !('images' in request.resource.data) || 
             request.resource.data.images.size() <= 20;
    }
    
    // Prevent suspicious price changes (more than 50% in single update)
    function isSuspiciousPriceChange(oldPrice, newPrice) {
      let change = (newPrice - oldPrice).abs() / oldPrice;
      return change > 0.5; // 50% change threshold
    }
    
    // ==================== COLLECTION RULES ====================
    
    // Users collection
    match /users/{userId} {
      // Read: Own profile or public data
      allow read: if isAuthenticated() && (isOwner(userId) || resource.data.get('public', false) == true);
      
      // Create: On sign up (via Cloud Functions preferably)
      allow create: if isAuthenticated() && 
                      isOwner(userId) &&
                      request.resource.data.keys().hasAll(['email', 'profileType', 'planTier']) &&
                      isValidProfileType(request.resource.data.profileType) &&
                      isValidPlanTier(request.resource.data.planTier) &&
                      !isBlocked();
      
      // Update: Own profile only, cannot change critical fields
      allow update: if isOwner(userId) &&
                      !isBlocked() &&
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'email', 'createdAt', 'planTier']) &&
                      isValidProfileType(request.resource.data.profileType);
      
      // Delete: Not allowed (use Cloud Functions for GDPR compliance)
      allow delete: if false;
      
      // AI usage tracking subcollection
      match /ai_usage/{document} {
        allow read: if isOwner(userId);
        allow write: if false; // Only Cloud Functions can write
      }
      
      // User settings subcollection
      match /settings/{document} {
        allow read, write: if isOwner(userId) && !isBlocked();
      }
    }
    
    // Cars collection (listings)
    match /cars/{carId} {
      // Read: Public listings
      allow read: if resource.data.get('status', 'draft') == 'active' || 
                    isOwner(resource.data.seller.id) ||
                    isAdmin();
      
      // Create: Authenticated users with quota
      allow create: if isAuthenticated() &&
                      !isBlocked() &&
                      isValidCarData(request.resource.data) &&
                      request.resource.data.seller.id == request.auth.uid &&
                      hasListingQuota(request.auth.uid, request.auth.token.get('planTier', 'free')) &&
                      hasValidImageCount(request.resource.data.images) &&
                      !isRateLimited(request.auth.uid);
      
      // Update: Owner only, some restrictions
      allow update: if isOwner(resource.data.seller.id) &&
                      !isBlocked() &&
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['seller', 'createdAt']) &&
                      hasValidImageCount(request.resource.data.images) &&
                      (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['price']) ||
                       !isSuspiciousPriceChange(resource.data.price, request.resource.data.price)) &&
                      !isRateLimited(request.auth.uid);
      
      // Delete: Owner or admin
      allow delete: if isOwner(resource.data.seller.id) || isAdmin();
    }
    
    // AI chat sessions (temporary conversation data)
    match /ai_chat_sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      !isBlocked() &&
                      hasAIQuota(request.auth.uid, request.auth.token.get('planTier', 'free'));
      allow update: if isOwner(resource.data.userId) && !isBlocked();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
    
    // AI price suggestions (cached results)
    match /ai_price_cache/{cacheId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions can write
    }
    
    // Duplicate detection logs (admin only)
    match /duplicate_detection_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }
    
    // Data processing logs (admin only)
    match /data_processing_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }
    
    // Image optimization logs (admin only)
    match /image_optimization_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions
    }
    
    // Admin review queue (admin only)
    match /admin_review_queue/{queueId} {
      allow read, update: if isAdmin();
      allow create, delete: if false; // Only Cloud Functions
    }
    
    // Rate limits collection (system managed)
    match /rate_limits/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions
    }
    
    // Fraud reports (authenticated users can report, admin can read)
    match /fraud_reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() &&
                      !isBlocked() &&
                      request.resource.data.reportedBy == request.auth.uid &&
                      request.resource.data.keys().hasAll(['carId', 'reason', 'reportedBy']);
      allow update, delete: if false; // Immutable after creation
    }
    
    // Analytics events (anonymous writes allowed, admin reads)
    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.keys().hasAll(['type', 'timestamp']);
      allow update, delete: if false;
    }
    
    // Search history (user-specific, auto-delete after 90 days)
    match /search_history/{userId}/{searchId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) &&
                      !isBlocked() &&
                      request.resource.data.timestamp > request.time - duration.value(90, 'd');
      allow update, delete: if isOwner(userId);
    }
    
    // Favorites/Saved listings
    match /favorites/{userId}/{carId} {
      allow read, write: if isOwner(userId) && !isBlocked();
    }
    
    // Messages (real-time messaging)
    match /messages/{conversationId}/messages/{messageId} {
      allow read: if isAuthenticated() &&
                    (resource.data.senderId == request.auth.uid || 
                     resource.data.recipientId == request.auth.uid);
      
      allow create: if isAuthenticated() &&
                      !isBlocked() &&
                      request.resource.data.senderId == request.auth.uid &&
                      request.resource.data.keys().hasAll(['senderId', 'recipientId', 'text', 'timestamp']) &&
                      request.resource.data.text is string &&
                      request.resource.data.text.size() >= 1 &&
                      request.resource.data.text.size() <= 5000 &&
                      !isRateLimited(request.auth.uid);
      
      allow update, delete: if false; // Messages are immutable
    }
    
    // Blocked users list (self-managed blocking)
    match /blocked_users/{userId}/blocked/{blockedUserId} {
      allow read, write: if isOwner(userId) && !isBlocked();
    }
    
    // ==================== DEFAULT DENY ====================
    // Anything not explicitly allowed is denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
