{\n  \"indexName\": \"listings_production\",\n  \"fieldMappings\": {\n    \"searchable\": [\n      \"title\",\n      \"description\",\n      \"make\",\n      \"model\",\n      \"sellerUsername\",\n      \"slug\",\n      \"canonicalUrl\"\n    ],\n    \"facets\": {\n      \"string\": [\n        \"brandId\",\n        \"modelId\",\n        \"fuelType\",\n        \"transmission\",\n        \"vehicleType\",\n        \"condition\",\n        \"city\",\n        \"status\"\n      ],\n      \"numeric\": [\n        \"year\",\n        \"mileage\",\n        \"price\",\n        \"enginePower\",\n        \"listingNumericId\",\n        \"sellerNumericId\"\n      ]\n    },\n    \"ranking\": [\n      \"listingQualityScore\",\n      \"updatedAt\",\n      \"viewCount\",\n      \"sellerTrustScore\"\n    ],\n    \"snippet\": {\n      \"attributesToHighlight\": [\n        \"title\",\n        \"description\",\n        \"make\",\n        \"model\"\n      ],\n      \"snippetEllipsisText\": \"…\"\n    },\n    \"seo\": {\n      \"canonical\": \"canonicalUrl\",\n      \"title\": \"title\",\n      \"description\": \"description\",\n      \"imageUrl\": \"primaryImageUrl\"\n    }\n  },\n  \"customRanking\": {\n    \"asc\": [\n      \"price\",\n      \"mileage\",\n      \"year\"\n    ],\n    \"desc\": [\n      \"listingQualityScore\",\n      \"updatedAt\",\n      \"sellerTrustScore\",\n      \"viewCount\"\n    ]\n  },\n  \"replicas\": [\n    {\n      \"name\": \"listings_by_price_asc\",\n      \"sortBy\": \"price:asc\"\n    },\n    {\n      \"name\": \"listings_by_price_desc\",\n      \"sortBy\": \"price:desc\"\n    },\n    {\n      \"name\": \"listings_by_mileage_asc\",\n      \"sortBy\": \"mileage:asc\"\n    },\n    {\n      \"name\": \"listings_by_newest\",\n      \"sortBy\": \"updatedAt:desc\"\n    }\n  ],\n  \"typoTolerance\": {\n    \"enabled\": true,\n    \"minWordSizeForTypos\": {\n      \"oneTypo\": 4,\n      \"twoTypos\": 8\n    },\n    \"disableOnWords\": [\n      \"BMW\",\n      \"VW\",\n      \"EUR\"\n    ]\n  },\n  \"pagination\": {\n    \"paginationLimitedTo\": 1000,\n    \"hitsPerPage\": 20\n  },\n  \"attributesForFaceting\": [\n    \"searchable(make)\",\n    \"searchable(model)\",\n    \"fuelType\",\n    \"transmission\",\n    \"year\",\n    \"city\",\n    \"condition\"\n  ],\n  \"version\": \"1.0\",\n  \"lastModified\": \"2026-02-18\",\n  \"syncStrategy\": \"trigger_on_listing_update\"\n}\n"