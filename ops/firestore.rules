// ⚠️ DEPRECATED: This is an OLD partial copy. The AUTHORITATIVE Firestore rules
// are at the project root: /firestore.rules (referenced by firebase.json).
// Do NOT deploy from this file.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for tests and development only
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin(request.auth.uid);
      allow delete: if isAdmin(request.auth.uid);
    }

    match /listings/{listingId} {
      allow read: if isListing(resource.data);
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid && validateListing(request.resource.data);
      allow update: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin(request.auth.uid)) && validateListing(request.resource.data);
      allow delete: if request.auth != null && (resource.data.sellerId == request.auth.uid || isAdmin(request.auth.uid));
    }

    match /stories/{storyId} {
      allow read: if isStory(resource.data);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin(request.auth.uid));
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin(request.auth.uid));
    }

    match /listings/{listingId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /short_links/{shortCode} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.createdBy == request.auth.uid || isAdmin(request.auth.uid));
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin(request.auth.uid);
      allow create: if request.auth != null;
      allow write: if false;  // immutable after creation
    }

    match /messages/{messageId} {
      allow read: if request.auth != null && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if false;  // immutable except read status
      allow delete: if request.auth != null && resource.data.senderId == request.auth.uid;
    }

    // Helper functions
    function isAdmin(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.roles.hasAny(['admin', 'devops']);
    }

    function isDealer(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.roles.hasAny(['dealer', 'admin']);
    }

    function validateListing(data) {
      return data.listingNumericId is int
        && data.brandId is string
        && data.modelId is string
        && data.year is int
        && data.price is number
        && data.currency is string
        && data.status in ['draft', 'published', 'archived', 'sold'];
    }

    function isListing(data) {
      return data.status == 'published' || data.status == 'archived';
    }

    function isStory(data) {
      return data.status == 'published';
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
