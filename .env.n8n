# إعدادات n8n للمشروع - حساب حقيقي
N8N_BASIC_AUTH_ACTIVE=false
N8N_CLOUD_URL=https://globul-cars-bg.app.n8n.cloud
N8N_PROTOCOL=https
WEBHOOK_URL=https://globul-cars-bg.app.n8n.cloud/webhook
N8N_EDITOR_BASE_URL=https://globul-cars-bg.app.n8n.cloud

# إعدادات قاعدة البيانات (SQLite للتطوير)
DB_TYPE=sqlite
DB_SQLITE_DATABASE=database.sqlite

# إعدادات Firebase للتكامل
FIREBASE_PROJECT_ID=fire-new-globul
FIREBASE_API_URL=https://fire-new-globul.firebaseapp.com

# إعدادات Globul Cars
GLOBUL_CARS_API_URL=http://localhost:3000
REACT_APP_N8N_URL=http://localhost:5678